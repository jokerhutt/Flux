    if ((prev_saved < 0) == (*? `& 1))
    {
        byte c = buf[--*?];
        *saved_byte = c;
    }
    else
        *saved_byte = -1;
    if (prev_saved < 0)
        return buf + 1;
    buf[1] = prev_saved;
    ++*?;
    return buf;
};

