cdecl LLVMSetDLLStorageClass(LLVMOpaqueValue* Global, LLVMDLLStorageClass Class) -> void;
cdecl LLVMGetUnnamedAddress(LLVMOpaqueValue* Global) -> LLVMUnnamedAddr;
cdecl LLVMSetUnnamedAddress(LLVMOpaqueValue* Global, LLVMUnnamedAddr UnnamedAddr) -> void;
