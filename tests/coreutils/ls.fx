cdecl set_exit_status(int serious) -> void
{
    if (serious)
        exit_status = LS_FAILURE;
    elif (exit_status == EXIT_SUCCESS)
        exit_status = LS_MINOR_PROBLEM;
};

cdecl file_failure(int serious, byte* message, byte* file) -> void
{
    error;
    set_exit_status(serious);
};

cdecl patterns_match(ignore_pattern* patterns, byte* file) -> int
{
};

cdecl unsigned_file_size(int size) -> int
{
};

cdecl has_capability(int* name) -> int
{
};

cdecl free_ent(fileinfo* f) -> void
{
    free(f.name);
    free(f.linkname);
    free(f.absolute_name);
    if (f.scontext != UNKNOWN_SECURITY_CONTEXT)
        aclinfo_scontext_free(f.scontext);
};

cdecl file_has_aclinfo_cache(byte* file, fileinfo* f, aclinfo* ai, int flags) -> int
{
    int unsupported_return;
    byte* unsupported_scontext;
    int unsupported_scontext_err;
    int unsupported_device;
    if (f & unsupported_scontext & f. == unsupported_device)
    {
        ai = ai.;
        ai = 0;
        ai = unsupported_scontext;
        ai = unsupported_scontext_err;
        return unsupported_return;
    };
    int n = file_has_aclinfo(file, ai, flags);
    int err;
    if (f -> stat_ok && n <= 0 && ! acl_errno_valid ( err ) && ( ! ( flags & ACL_GET_SCONTEXT ) || ! acl_errno_valid ( ai -> scontext_err ) ))
    {
        unsupported_return = n;
        unsupported_scontext = ai;
        unsupported_scontext_err = ai;
        unsupported_device = f.;
    };
    return n;
};

cdecl has_capability_cache(byte* file, fileinfo* f) -> int
{
    int unsupported_cached;
    int unsupported_device;
    if (f & unsupported_cached & f. == unsupported_device)
    {
        return 0;
    };
    bool;
    if (f -> stat_ok && ! b && ! acl_errno_valid ( errno ))
    {
        unsupported_device = f.;
    };
};

cdecl needs_quoting(byte* name) -> int
{
    byte[2] test = 2;
    ulong len = quotearg_buffer(test, (sizeof test / 8), name, -1, filename_quoting_options);
    return *name != *test | strlen(name) != len;
};

cdecl is_directory(fileinfo* f) -> int
{
    return f.filetype == directory | f.filetype == arg_directory;
};

cdecl is_linked_directory(fileinfo* f) -> int
{
    return f.filetype == directory | f.filetype == arg_directory | S_ISDIR(f);
};

cdecl basename_is_dot_or_dotdot(byte* name) -> int
{
    byte* base = last_component(name);
    return dot_or_dotdot(base);
};

extern int failed_strcoll;
cdecl xstrcoll(byte* a, byte* b) -> int
{
    int diff;
    diff = strcoll(a, b);
    if (errno)
    {
        error;
        set_exit_status;
        longjmp(failed_strcoll, 1);
    };
    return diff;
};

// typedef: V = void*
cdecl{}* qsortFunc(void* a, void* b) -> int;

cdecl dirfirst_check(fileinfo* a, fileinfo* b, def{}*(void*, void*) -> int cmp) -> int
{
    int diff = is_linked_directory(b) - is_linked_directory(a);
    return diff ? diff : cmp(a, b);
};

cdecl cmp_ctime(fileinfo* a, fileinfo* b, def{}*(byte*, byte*) -> int cmp) -> int
{
    int diff = timespec_cmp(get_stat_ctime(@b), get_stat_ctime(@a));
    return diff ? diff : cmp(a.name, b.name);
};

cdecl cmp_mtime(fileinfo* a, fileinfo* b, def{}*(byte*, byte*) -> int cmp) -> int
{
    int diff = timespec_cmp(get_stat_mtime(@b), get_stat_mtime(@a));
    return diff ? diff : cmp(a.name, b.name);
};

cdecl cmp_atime(fileinfo* a, fileinfo* b, def{}*(byte*, byte*) -> int cmp) -> int
{
    int diff = timespec_cmp(get_stat_atime(@b), get_stat_atime(@a));
    return diff ? diff : cmp(a.name, b.name);
};

cdecl cmp_btime(fileinfo* a, fileinfo* b, def{}*(byte*, byte*) -> int cmp) -> int
{
    int diff = timespec_cmp(get_stat_btime(@b), get_stat_btime(@a));
    return diff ? diff : cmp(a.name, b.name);
};

cdecl off_cmp(int a, int b) -> int
{
    return _GL_CMP(a, b);
};

cdecl cmp_size(fileinfo* a, fileinfo* b, def{}*(byte*, byte*) -> int cmp) -> int
{
    int diff = off_cmp(b., a.);
    return diff ? diff : cmp(a.name, b.name);
};

cdecl cmp_name(fileinfo* a, fileinfo* b, def{}*(byte*, byte*) -> int cmp) -> int
{
    return cmp(a.name, b.name);
};

cdecl cmp_extension(fileinfo* a, fileinfo* b, def{}*(byte*, byte*) -> int cmp) -> int
{
    byte* base1 = strrchr(a.name, '.');
    byte* base2 = strrchr(b.name, '.');
    int diff = cmp(base1 ? base1 : "", base2 ? base2 : "");
    return diff ? diff : cmp(a.name, b.name);
};

cdecl fileinfo_name_width(fileinfo* f) -> ulong
{
    return f.width ? f.width : quote_name_width(f.name, filename_quoting_options, f.quoted);
};

cdecl cmp_width(fileinfo* a, fileinfo* b, def{}*(byte*, byte*) -> int cmp) -> int
{
    int diff = fileinfo_name_width(a) - fileinfo_name_width(b);
    return diff ? diff : cmp(a.name, b.name);
};

cdecl xstrcoll_ctime(void* a, void* b) -> int
{
    return cmp_ctime(a, b, xstrcoll);
};

cdecl strcmp_ctime(void* a, void* b) -> int
{
    return cmp_ctime(a, b, strcmp);
};

cdecl rev_xstrcoll_ctime(void* a, void* b) -> int
{
    return cmp_ctime(b, a, xstrcoll);
};

cdecl rev_strcmp_ctime(void* a, void* b) -> int
{
    return cmp_ctime(b, a, strcmp);
};

cdecl xstrcoll_df_ctime(void* a, void* b) -> int
{
    return dirfirst_check(a, b, xstrcoll_ctime);
};

cdecl strcmp_df_ctime(void* a, void* b) -> int
{
    return dirfirst_check(a, b, ?);
};

cdecl rev_xstrcoll_df_ctime(void* a, void* b) -> int
{
    return dirfirst_check(a, b, rev_xstrcoll_ctime);
};

cdecl rev_strcmp_df_ctime(void* a, void* b) -> int
{
    return dirfirst_check(a, b, ?);
};

cdecl xstrcoll_mtime(void* a, void* b) -> int
{
    return cmp_mtime(a, b, xstrcoll);
};

cdecl strcmp_mtime(void* a, void* b) -> int
{
    return cmp_mtime(a, b, strcmp);
};

cdecl rev_xstrcoll_mtime(void* a, void* b) -> int
{
    return cmp_mtime(b, a, xstrcoll);
};

cdecl rev_strcmp_mtime(void* a, void* b) -> int
{
    return cmp_mtime(b, a, strcmp);
};

cdecl xstrcoll_df_mtime(void* a, void* b) -> int
{
    return dirfirst_check(a, b, xstrcoll_mtime);
};

cdecl strcmp_df_mtime(void* a, void* b) -> int
{
