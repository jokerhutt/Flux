*
* Update the specified successor to point at the provided block.
*
* @see llvm::Instruction::setSuccessor

///

cdecl LLVMSetSuccessor(LLVMOpaqueValue* Term, uint i, LLVMOpaqueBasicBlock* block) -> void;
