"));
        oputs_("stat", gettext("\
  -f, --file-system\n\
         display file system status instead of file status\n\
"));
        oputs_("stat", gettext("\
      --cached=MODE\n\
         specify how to use cached attributes;\n\
         useful on remote file systems. See MODE below\n\
"));
