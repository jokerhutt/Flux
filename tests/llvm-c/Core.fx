* Deprecated: Use LLVMGetUnnamedAddress instead.
///

cdecl LLVMHasUnnamedAddr(LLVMOpaqueValue* Global) -> int;
///
* Deprecated: Use LLVMSetUnnamedAddress instead.
///

cdecl LLVMSetUnnamedAddr(LLVMOpaqueValue* Global, int HasUnnamedAddr) -> void;
///
*
* @defgroup LLVMCCoreValueWithAlignment Values with alignment
*
* Functions in this group only apply to values with alignment, i.e.
* global variables, load and store instructions.

///

///
*
* Obtain the preferred alignment of the value.
* @see llvm::AllocaInst::getAlignment()
* @see llvm::LoadInst::getAlignment()
* @see llvm::StoreInst::getAlignment()
* @see llvm::AtomicRMWInst::setAlignment()
* @see llvm::AtomicCmpXchgInst::setAlignment()
* @see llvm::GlobalValue::getAlignment()

///

cdecl LLVMGetAlignment(LLVMOpaqueValue* V) -> uint;
///
*
* Set the preferred alignment of the value.
* @see llvm::AllocaInst::setAlignment()
* @see llvm::LoadInst::setAlignment()
* @see llvm::StoreInst::setAlignment()
* @see llvm::AtomicRMWInst::setAlignment()
* @see llvm::AtomicCmpXchgInst::setAlignment()
* @see llvm::GlobalValue::setAlignment()

///

cdecl LLVMSetAlignment(LLVMOpaqueValue* V, uint Bytes) -> void;
///
*
* Sets a metadata attachment, erasing the existing metadata attachment if
* it already exists for the given kind.
*
* @see llvm::GlobalObject::setMetadata()

///

cdecl LLVMGlobalSetMetadata(LLVMOpaqueValue* Global, uint Kind, LLVMOpaqueMetadata* MD) -> void;
///
*
* Adds a metadata attachment.
*
* @see llvm::GlobalObject::addMetadata()

///

cdecl LLVMGlobalAddMetadata(LLVMOpaqueValue* Global, uint Kind, LLVMOpaqueMetadata* MD) -> void;
///
*
* Erases a metadata attachment of the given kind if it exists.
*
* @see llvm::GlobalObject::eraseMetadata()

///

cdecl LLVMGlobalEraseMetadata(LLVMOpaqueValue* Global, uint Kind) -> void;
///
*
* Removes all metadata attachments from this value.
*
* @see llvm::GlobalObject::clearMetadata()

///

cdecl LLVMGlobalClearMetadata(LLVMOpaqueValue* Global) -> void;
///
*
* Add debuginfo metadata to this global.
*
* @see llvm::GlobalVariable::addDebugInfo()

///

cdecl LLVMGlobalAddDebugInfo(LLVMOpaqueValue* Global, LLVMOpaqueMetadata* GVE) -> void;
///
*
* Retrieves an array of metadata entries representing the metadata attached to
* this value. The caller is responsible for freeing this array by calling
* \c LLVMDisposeValueMetadataEntries.
*
* @see llvm::GlobalObject::getAllMetadata()

///

cdecl LLVMGlobalCopyAllMetadata(LLVMOpaqueValue* Value, ulong* NumEntries) -> LLVMOpaqueValueMetadataEntry*;
///
*
* Destroys value metadata entries.

///

cdecl LLVMDisposeValueMetadataEntries(LLVMOpaqueValueMetadataEntry* Entries) -> void;
///
*
* Returns the kind of a value metadata entry at a specific index.

///

cdecl LLVMValueMetadataEntriesGetKind(LLVMOpaqueValueMetadataEntry* Entries, uint Index) -> uint;
///
*
* Returns the underlying metadata node of a value metadata entry at a
* specific index.

///

cdecl LLVMValueMetadataEntriesGetMetadata(LLVMOpaqueValueMetadataEntry* Entries, uint Index) -> LLVMOpaqueMetadata*;
///
*
* @}

