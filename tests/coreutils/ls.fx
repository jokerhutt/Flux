{
    PS_START = 1,
    PS_2 = 2,
    PS_3 = 3,
    PS_4 = 4,
    PS_DONE = 5,
    PS_FAIL = 6
};

cdecl known_term_type() -> int
{
    byte* term = getenv("TERM");
