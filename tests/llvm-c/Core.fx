///
*
* Get the string attribute's kind.

///

cdecl LLVMGetStringAttributeKind(LLVMOpaqueAttributeRef* A, uint* Length) -> byte*;
///
*
* Get the string attribute's value.

///

cdecl LLVMGetStringAttributeValue(LLVMOpaqueAttributeRef* A, uint* Length) -> byte*;
