cdecl align_nstrftime(byte* buf, ulong size, int recent, tm* tm, int tz, int ns) -> int
{
    byte* nfmt = (use_abformat ? abformat[recent][tm] : long_time_format[recent]);
    return nstrftime(buf, size, nfmt, tm, tz, ns);
};

cdecl long_time_expected_width() -> int
{
    int width = -1;
    if (width < 0)
    {
        tm tm;
        byte[1] buf = TIME_STAMP_LEN_MAXIMUM + 1;
        if (localtime_rz)
        {
            if (len > 0)
                width = mbsnwidth;
        };
        if (width < 0)
            width = 0;
    };
    return width;
};

cdecl format_user_or_group(byte* name, int id, int width) -> void
{
    if (name)
    {
        int name_width = mbswidth(name, MBSWIDTH_FLAGS);
        int width_gap = name_width < 0 ? 0 : width - name_width;
        int pad = MAX(0, width_gap);
        dired_outstring(name);
        do
            dired_outbyte(' ');
        while (pad--);
    }
    else
        dired_pos += printf("%*ju ", width, id);
};

cdecl format_user(int u, int width, int stat_ok) -> void
{
    format_user_or_group;
};

cdecl format_group(int g, int width, int stat_ok) -> void
{
    format_user_or_group;
};

cdecl format_user_or_group_width(byte* name, int id) -> int
{
    return (name ? mbswidth(name, MBSWIDTH_FLAGS) : snprintf);
};

cdecl format_inode(void* /* untranslated: char[<recovery-expr>(INT_BUFSIZE_BOUND)] */ buf, fileinfo* f) -> byte*
{
    return (f & f. != NOT_AN_INODE_NUMBER ? umaxtostr(f., buf) : (byte*)"?");
};

cdecl file_escape(byte* str, int path) -> byte*
{
    byte* esc = xnmalloc(3, strlen(str) + 1);
    byte* p = esc;
    while (*str)
    {
        if (path & ISSLASH(*str))
        {
            *p++ = '/';
            str++;
        }
        elif (RFC3986[to_uchar(*str)])
            *p++ = *str++;
        else
            p += sprintf(p, "%%%02x", to_uchar(*str++));
    };
    *p = '\0';
    return esc;
};

cdecl get_type_indicator(int stat_ok, int mode, filetype type) -> byte
{
    byte c;
    if (stat_ok ? S_ISREG(mode) : type == normal)
    {
        if (stat_ok && indicator_style == classify && ( mode & S_IXUGO ))
            c = '*';
        else
            c = 0;
    }
    else
    {
        if (stat_ok ? S_ISDIR(mode) : type == directory | type == arg_directory)
            c = '/';
        elif (indicator_style == slash)
            c = 0;
        else
            if (stat_ok ? S_ISLNK(mode) : type == symbolic_link)
                c = '@';
            elif (stat_ok ? S_ISFIFO(mode) : type == fifo)
                c = '|';
            else
                if (stat_ok ? S_ISSOCK(mode) : type == sock)
                    c = '=';
                elif (stat_ok & S_ISDOOR(mode))
                    c = '>';
                else
                    c = 0;
    };
    return c;
};

cdecl length_of_file_name_and_frills(fileinfo* f) -> ulong
{
    ulong len = 0;
    void* /* untranslated: char[<recovery-expr>(MAX, <recovery-expr>(INT_BUFSIZE_BOUND))] */ buf = MAX;
    if (print_inode)
        len += 1 + (format == with_commas ? strlen(umaxtostr(f., buf)) : inode_number_width);
    if (print_block_size)
        len += 1 + (format == with_commas ? strlen(!f ? "?" : human_readable) : block_size_width);
    if (print_scontext)
        len += 1 + (format == with_commas ? strlen(f.scontext) : scontext_width);
    len += fileinfo_name_width(f);
    if (indicator_style != none)
    {
        byte c = get_type_indicator(f, f., f.filetype);
        len += (c != 0);
    };
    return len;
};

cdecl init_column_info(int max_cols) -> void
{
    int column_info_alloc;
    if (column_info_alloc < max_cols)
    {
        column_info = xpalloc(column_info, @column_info_alloc, max_cols - column_info_alloc, -1, (sizeof * column_info / 8));
        if (ckd_add | ckd_mul)
            xalloc_die();
        ulong* p = xinmalloc;
    };
};

cdecl usage(int status) -> void
{
    if (status != EXIT_SUCCESS)
        do
        {
            fprintf;
        }
        while (0);
    else
    {
        printf;
        fputs;
        emit_mandatory_arg_note();
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -a, --all\n\
         do not ignore entries starting with .\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -A, --almost-all\n\
         do not list implied . and ..\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
      --author\n\
         with -l, print the author of each file\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -b, --escape\n\
         print C-style escapes for nongraphic characters\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
      --block-size=SIZE\n\
         with -l, scale sizes by SIZE when printing them;\n\
         e.g., '--block-size=M'; see SIZE format below\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -B, --ignore-backups\n\
         do not list implied entries ending with ~\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -c\n\
         with -lt: sort by, and show, ctime\n\
           (time of last change of file status information);\n\
         with -l: show ctime and sort by name;\n\
         otherwise: sort by ctime, newest first\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -C\n\
