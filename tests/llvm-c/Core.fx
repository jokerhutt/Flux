*
* Returns the synchronization scope ID of an atomic instruction.

///

cdecl LLVMGetAtomicSyncScopeID(LLVMOpaqueValue* AtomicInst) -> uint;
///
*
* Sets the synchronization scope ID of an atomic instruction.

///

cdecl LLVMSetAtomicSyncScopeID(LLVMOpaqueValue* AtomicInst, uint SSID) -> void;
cdecl LLVMGetCmpXchgSuccessOrdering(LLVMOpaqueValue* CmpXchgInst) -> LLVMAtomicOrdering;
cdecl LLVMSetCmpXchgSuccessOrdering(LLVMOpaqueValue* CmpXchgInst, LLVMAtomicOrdering Ordering) -> void;
cdecl LLVMGetCmpXchgFailureOrdering(LLVMOpaqueValue* CmpXchgInst) -> LLVMAtomicOrdering;
cdecl LLVMSetCmpXchgFailureOrdering(LLVMOpaqueValue* CmpXchgInst, LLVMAtomicOrdering Ordering) -> void;
