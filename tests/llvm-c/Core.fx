* This only works on llvm::SwitchInst instructions.
*
* @see llvm::SwitchInst::CaseHandle::getCaseValue()

///

cdecl LLVMGetSwitchCaseValue(LLVMOpaqueValue* SwitchInstr, uint i) -> LLVMOpaqueValue*;
