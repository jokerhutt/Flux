cdecl output_one_dumb_line() -> void
{
    if (!right_reference)
    {
        if (auto_reference)
        {
            print_field(reference);
            putchar(':');
            print_spaces(reference_max_width + gap_size - (reference.end - reference.start) - 1);
        }
        else
        {
            print_field(reference);
            print_spaces(reference_max_width + gap_size - (reference.end - reference.start));
        };
    };
    if (tail.start < tail.end)
    {
        print_field(tail);
        if (tail_truncation)
            fputs;
        print_spaces(half_line_width - gap_size - (before.end - before.start) - (before_truncation ? truncation_string_length : 0) - (tail.end - tail.start) - (tail_truncation ? truncation_string_length : 0));
    }
    else
        print_spaces(half_line_width - gap_size - (before.end - before.start) - (before_truncation ? truncation_string_length : 0));
    if (before_truncation)
        fputs;
    print_field(before);
    print_spaces(gap_size);
    print_field(keyafter);
    if (keyafter_truncation)
        fputs;
    if (head.start < head.end)
    {
        print_spaces(half_line_width - (keyafter.end - keyafter.start) - (keyafter_truncation ? truncation_string_length : 0) - (head.end - head.start) - (head_truncation ? truncation_string_length : 0));
        if (head_truncation)
            fputs;
        print_field(head);
    }
    elif ((auto_reference | input_reference) & right_reference)
        print_spaces(half_line_width - (keyafter.end - keyafter.start) - (keyafter_truncation ? truncation_string_length : 0));
    if ((auto_reference | input_reference) & right_reference)
    {
        print_spaces(gap_size);
        print_field(reference);
    };
    putchar('\n');
};

cdecl generate_all_output() -> void
{
    struct (unnamed at tests/coreutils/ptx.c:222:9)* occurs_cursor;
    occurs_cursor = occurs_table[0];
};

cdecl usage(int status) -> void
{
    if (status != EXIT_SUCCESS)
        do
        {
            fprintf;
        }
        while (0);
    else
    {
        printf;
        fputs;
        emit_stdin_note();
        emit_mandatory_arg_note();
        oputs_("ptx", gettext("\
  -A, --auto-reference           output automatically generated references\n\
"));
        oputs_("ptx", gettext("\
  -G, --traditional              behave more like System V 'ptx'\n\
"));
        oputs_("ptx", gettext("\
  -F, --flag-truncation=STRING   use STRING for flagging line truncations.\n\
                                 The default is '/'\n\
"));
        oputs_("ptx", gettext("\
  -M, --macro-name=STRING        macro name to use instead of 'xx'\n\
"));
        oputs_("ptx", gettext("\
  -O, --format=roff              generate output as roff directives\n\
"));
        oputs_("ptx", gettext("\
  -R, --right-side-refs          put references at right, not counted in -w\n\
"));
        oputs_("ptx", gettext("\
  -S, --sentence-regexp=REGEXP   for end of lines or end of sentences\n\
"));
        oputs_("ptx", gettext("\
  -T, --format=tex               generate output as TeX directives\n\
"));
        oputs_("ptx", gettext("\
  -W, --word-regexp=REGEXP       use REGEXP to match each keyword\n\
"));
        oputs_("ptx", gettext("\
  -b, --break-file=FILE          word break characters in this FILE\n\
"));
        oputs_("ptx", gettext("\
  -f, --ignore-case              fold lower case to upper case for sorting\n\
"));
        oputs_("ptx", gettext("\
  -g, --gap-size=NUMBER          gap size in columns between output fields\n\
"));
        oputs_("ptx", gettext("\
  -i, --ignore-file=FILE         read ignore word list from FILE\n\
"));
        oputs_("ptx", gettext("\
  -o, --only-file=FILE           read only word list from this FILE\n\
"));
        oputs_("ptx", gettext("\
  -r, --references               first field of each line is a reference\n\
"));
        oputs_("ptx", gettext("\
  -t, --typeset-mode             change the default width from 72 to 100\n\
"));
        oputs_("ptx", gettext("\
  -w, --width=NUMBER             output width in columns, reference excluded\n\
"));
        oputs_("ptx", gettext("      --help\n         display this help and exit\n"));
        oputs_("ptx", gettext("      --version\n         output version information and exit\n"));
        emit_ancillary_info("ptx");
    };
    exit(status);
};

uint FORMAT_OPTION = 0;

struct option;
extern int long_options;
extern byte** format_args;
Format[2] format_vals = Format;
cdecl main(int argc, byte** argv) -> int
{
    int optchar;
    int file_index;
    set_program_name(argv[0]);
    setlocale;
    atexit;
    while (optchar = getopt_long ( argc , argv , "AF:GM:ORS:TW:b:i:fg:o:trw:" , long_options , NULL ) , optchar != EOF)
    {
    };
    if (line_width < 0)
        line_width = 72;
    if (optind == argc)
    {
        input_file_name = xmalloc((sizeof * input_file_name / 8));
        file_line_count = xmalloc((sizeof * file_line_count / 8));
        text_buffers = xmalloc((sizeof * text_buffers / 8));
        number_input_files = 1;
    }
    elif (gnu_extensions)
    {
        input_file_name = xnmalloc(number_input_files, (sizeof * input_file_name / 8));
        file_line_count = xnmalloc(number_input_files, (sizeof * file_line_count / 8));
        text_buffers = xnmalloc(number_input_files, (sizeof * text_buffers / 8));
        for (file_index = 0; file_index < number_input_files; file_index++)
        {
        };
    };
    else
    {
        number_input_files = 1;
        input_file_name = xmalloc((sizeof * input_file_name / 8));
        file_line_count = xmalloc((sizeof * file_line_count / 8));
        text_buffers = xmalloc((sizeof * text_buffers / 8));
        if (optind < argc)
        {
            if (!freopen)
                error;
        };
        if (optind < argc)
        {
            error(0, 0, gettext("extra operand %s"), quote);
            usage;
        };
    };
    if (output_format == UNKNOWN_FORMAT)
        output_format = gnu_extensions ? DUMB_FORMAT : ROFF_FORMAT;
    initialize_regex();
    if (break_file)
        digest_break_file(break_file);
    if (ignore_file)
    {
        digest_word_file(ignore_file, @ignore_table);
    };
    if (only_file)
    {
        digest_word_file(only_file, @only_table);
    };
    number_of_occurs[0] = 0;
    total_line_count = 0;
    maximum_word_length = 0;
    reference_max_width = 0;
    for (file_index = 0; file_index < number_input_files; file_index++)
    {
        BLOCK* text_buffer = text_buffers + file_index;
        swallow_file_in_memory(input_file_name[file_index], text_buffer);
        find_occurs_in_text(file_index);
        total_line_count++;
        file_line_count[file_index] = total_line_count;
    };
    sort_found_occurs();
    fix_output_parameters();
    generate_all_output();
};
