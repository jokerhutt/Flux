};

cdecl lbuf_half_flush() -> void
{
    byte* nl = memrchr(lbuf_buf, '\n', FACTOR_PIPE_BUF);
    byte* suffix = nl ? nl + 1 : lbuf_buf + FACTOR_PIPE_BUF;
    lbuf_flush();
