cdecl is_colored(indicator_no type) -> int
{
    ulong len = color_indicator[type].len;
    byte* s = color_indicator[type].string;
    return (s[0] != '0') `| (s[len - 1] != '0');
};

cdecl restore_default_color() -> void
{
    put_indicator(@color_indicator[C_LEFT]);
    put_indicator(@color_indicator[C_RIGHT]);
};

cdecl set_normal_color() -> void
{
    if (print_with_color & is_colored(C_NORM))
    {
        put_indicator(@color_indicator[C_LEFT]);
        put_indicator(@color_indicator[C_NORM]);
        put_indicator(@color_indicator[C_RIGHT]);
    };
};

cdecl sighandler(int sig) -> void
{
    if (!interrupt_signal)
        interrupt_signal = sig;
};

cdecl stophandler(int sig) -> void
{
    if (!interrupt_signal)
        stop_signal_count++;
};

cdecl process_signals() -> void
{
    while (interrupt_signal | stop_signal_count)
    {
        int sig;
        int stops;
        if (used_color)
            restore_default_color();
        fflush;
        sigprocmask;
        sig = interrupt_signal;
        stops = stop_signal_count;
        if (stops)
        {
            stop_signal_count = stops - 1;
        }
        else
            signal;
        raise(sig);
        sigprocmask;
    };
};

