///
*
* @defgroup LLVMCCoreModuleProvider Module Providers
*
* @{

///

///
*
* Changes the type of M so it can be passed to FunctionPassManagers and the
* JIT.  They take ModuleProviders for historical reasons.

///

cdecl LLVMCreateModuleProviderForExistingModule(LLVMOpaqueModule* M) -> LLVMOpaqueModuleProvider*;
///
*
* Destroys the module M.

///

cdecl LLVMDisposeModuleProvider(LLVMOpaqueModuleProvider* M) -> void;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreMemoryBuffers Memory Buffers
*
* @{

///

cdecl LLVMCreateMemoryBufferWithContentsOfFile(byte* Path, LLVMOpaqueMemoryBuffer** OutMemBuf, byte** OutMessage) -> int;
cdecl LLVMCreateMemoryBufferWithSTDIN(LLVMOpaqueMemoryBuffer** OutMemBuf, byte** OutMessage) -> int;
cdecl LLVMCreateMemoryBufferWithMemoryRange(byte* InputData, ulong InputDataLength, byte* BufferName, int RequiresNullTerminator) -> LLVMOpaqueMemoryBuffer*;
cdecl LLVMCreateMemoryBufferWithMemoryRangeCopy(byte* InputData, ulong InputDataLength, byte* BufferName) -> LLVMOpaqueMemoryBuffer*;
cdecl LLVMGetBufferStart(LLVMOpaqueMemoryBuffer* MemBuf) -> byte*;
cdecl LLVMGetBufferSize(LLVMOpaqueMemoryBuffer* MemBuf) -> ulong;
cdecl LLVMDisposeMemoryBuffer(LLVMOpaqueMemoryBuffer* MemBuf) -> void;
///
*
* @}

///

///
*
* @defgroup LLVMCCorePassManagers Pass Managers
* @ingroup LLVMCCore
*
* @{

///

///
* Constructs a new whole-module pass pipeline. This type of pipeline is
 suitable for link-time optimization and whole-module transformations.
 @see llvm::PassManager::PassManager
///

cdecl LLVMCreatePassManager() -> LLVMOpaquePassManager*;
///
* Constructs a new function-by-function pass pipeline over the module
 provider. It does not take ownership of the module provider. This type of
 pipeline is suitable for code generation and JIT compilation tasks.
 @see llvm::FunctionPassManager::FunctionPassManager
///

cdecl LLVMCreateFunctionPassManagerForModule(LLVMOpaqueModule* M) -> LLVMOpaquePassManager*;
///
* Deprecated: Use LLVMCreateFunctionPassManagerForModule instead.
///

cdecl LLVMCreateFunctionPassManager(LLVMOpaqueModuleProvider* MP) -> LLVMOpaquePassManager*;
///
* Initializes, executes on the provided module, and finalizes all of the
 passes scheduled in the pass manager. Returns 1 if any of the passes
 modified the module, 0 otherwise.
 @see llvm::PassManager::run(Module&)
///

cdecl LLVMRunPassManager(LLVMOpaquePassManager* PM, LLVMOpaqueModule* M) -> int;
///
* Initializes all of the function passes scheduled in the function pass
 manager. Returns 1 if any of the passes modified the module, 0 otherwise.
 @see llvm::FunctionPassManager::doInitialization
///

cdecl LLVMInitializeFunctionPassManager(LLVMOpaquePassManager* FPM) -> int;
///
* Executes all of the function passes scheduled in the function pass manager
 on the provided function. Returns 1 if any of the passes modified the
 function, false otherwise.
 @see llvm::FunctionPassManager::run(Function&)
///

cdecl LLVMRunFunctionPassManager(LLVMOpaquePassManager* FPM, LLVMOpaqueValue* F) -> int;
///
* Finalizes all of the function passes scheduled in the function pass
 manager. Returns 1 if any of the passes modified the module, 0 otherwise.
 @see llvm::FunctionPassManager::doFinalization
///

cdecl LLVMFinalizeFunctionPassManager(LLVMOpaquePassManager* FPM) -> int;
///
* Frees the memory of a pass pipeline. For function pipelines, does not free
 the module provider.
 @see llvm::PassManagerBase::~PassManagerBase.
///

cdecl LLVMDisposePassManager(LLVMOpaquePassManager* PM) -> void;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreThreading Threading
*
* Handle the structures needed to make LLVM safe for multithreading.
*
* @{

///

///
* Deprecated: Multi-threading can only be enabled/disabled with the compile
 time define LLVM_ENABLE_THREADS.  This function always returns
 LLVMIsMultithreaded().
///

cdecl LLVMStartMultithreaded() -> int;
///
* Deprecated: Multi-threading can only be enabled/disabled with the compile
 time define LLVM_ENABLE_THREADS.
///

cdecl LLVMStopMultithreaded() -> void;
///
* Check whether LLVM is executing in thread-safe mode or not.
 @see llvm::llvm_is_multithreaded
///

cdecl LLVMIsMultithreaded() -> int;
///
*
* @}

