///

///
*
* @defgroup LLVMCCoreModule Modules
*
* Modules represent the top-level structure in an LLVM program. An LLVM
* module is effectively a translation unit or a collection of
* translation units merged together.
*
* @{

///

///
*
* Create a new, empty module in the global context.
*
* This is equivalent to calling LLVMModuleCreateWithNameInContext with
* LLVMGetGlobalContext() as the context parameter.
*
* Every invocation should be paired with LLVMDisposeModule() or memory
* will be leaked.

///

cdecl LLVMModuleCreateWithName(byte* ModuleID) -> LLVMOpaqueModule*;
///
*
* Create a new, empty module in a specific context.
*
* Every invocation should be paired with LLVMDisposeModule() or memory
* will be leaked.

///

cdecl LLVMModuleCreateWithNameInContext(byte* ModuleID, LLVMOpaqueContext* C) -> LLVMOpaqueModule*;
///
*
* Return an exact copy of the specified module.

///

cdecl LLVMCloneModule(LLVMOpaqueModule* M) -> LLVMOpaqueModule*;
///
*
* Destroy a module instance.
*
* This must be called for every created module or memory will be
* leaked.

///

cdecl LLVMDisposeModule(LLVMOpaqueModule* M) -> void;
