///
Verifies that a module is valid, taking the specified action if not.
Optionally returns a human-readable description of any invalid constructs.
OutMessage must be disposed with LLVMDisposeMessage.
///

cdecl LLVMVerifyModule(LLVMOpaqueModule* M, LLVMVerifierFailureAction Action, byte** OutMessage) -> int;
///
Verifies that a single function is valid, taking the specified action. Useful
for debugging.
///

cdecl LLVMVerifyFunction(LLVMOpaqueValue* Fn, LLVMVerifierFailureAction Action) -> int;
///
Open up a ghostview window that displays the CFG of the current function.
Useful for debugging.
///

cdecl LLVMViewFunctionCFG(LLVMOpaqueValue* Fn) -> void;
cdecl LLVMViewFunctionCFGOnly(LLVMOpaqueValue* Fn) -> void;
