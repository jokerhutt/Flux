                format = xasprintf("%s%s", format, gettext("\
"));
            }
            else
            {
                format = xasprintf("%s%s", format, gettext("\
"));
            };
            free(temp);
            temp = format;
            format = xasprintf("%s%s", format, gettext("\
"));
            free(temp);
            if (0 < is_selinux_enabled())
            {
                temp = format;
                format = xasprintf("%s%s", format, gettext("Context: %C\n"));
                free(temp);
            };
            temp = format;
            format = xasprintf("%s%s", format, gettext("Access: %x\n"));
            free(temp);
        };
    };
    return format;
};

