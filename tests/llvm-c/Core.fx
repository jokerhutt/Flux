cdecl LLVMConstAddrSpaceCast(LLVMOpaqueValue* ConstantVal, LLVMOpaqueType* ToType) -> LLVMOpaqueValue*;
cdecl LLVMConstTruncOrBitCast(LLVMOpaqueValue* ConstantVal, LLVMOpaqueType* ToType) -> LLVMOpaqueValue*;
cdecl LLVMConstPointerCast(LLVMOpaqueValue* ConstantVal, LLVMOpaqueType* ToType) -> LLVMOpaqueValue*;
