     advances by skipping single separators or whole words. */ before . start = left_field_start ; before . end = keyafter . start ; SKIP_WHITE_BACKWARDS ( before . end , before . start ) ; while ( before . start + before_max_width < before . end ) SKIP_SOMETHING ( before . start , before . end ))
                matcher_error();
        }
        elif (word_fastmap[to_uchar(*before.start)])
