cdecl LLVMConstNSWAdd(LLVMOpaqueValue* LHSConstant, LLVMOpaqueValue* RHSConstant) -> LLVMOpaqueValue*;
cdecl LLVMConstNUWAdd(LLVMOpaqueValue* LHSConstant, LLVMOpaqueValue* RHSConstant) -> LLVMOpaqueValue*;
cdecl LLVMConstSub(LLVMOpaqueValue* LHSConstant, LLVMOpaqueValue* RHSConstant) -> LLVMOpaqueValue*;
cdecl LLVMConstNSWSub(LLVMOpaqueValue* LHSConstant, LLVMOpaqueValue* RHSConstant) -> LLVMOpaqueValue*;
cdecl LLVMConstNUWSub(LLVMOpaqueValue* LHSConstant, LLVMOpaqueValue* RHSConstant) -> LLVMOpaqueValue*;
cdecl LLVMConstXor(LLVMOpaqueValue* LHSConstant, LLVMOpaqueValue* RHSConstant) -> LLVMOpaqueValue*;
cdecl LLVMConstGEP2(LLVMOpaqueType* Ty, LLVMOpaqueValue* ConstantVal, LLVMOpaqueValue** ConstantIndices, uint NumIndices) -> LLVMOpaqueValue*;
cdecl LLVMConstInBoundsGEP2(LLVMOpaqueType* Ty, LLVMOpaqueValue* ConstantVal, LLVMOpaqueValue** ConstantIndices, uint NumIndices) -> LLVMOpaqueValue*;
