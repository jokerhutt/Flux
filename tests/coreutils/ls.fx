{
    return dirfirst_check(a, b, ?);
};

cdecl cmp_version(fileinfo* a, fileinfo* b) -> int
{
    int diff = filevercmp(a.name, b.name);
    return diff ? diff : strcmp(a.name, b.name);
};

cdecl xstrcoll_version(void* a, void* b) -> int
{
    return cmp_version(a, b);
};

cdecl rev_xstrcoll_version(void* a, void* b) -> int
{
    return cmp_version(b, a);
};

cdecl xstrcoll_df_version(void* a, void* b) -> int
{
    return dirfirst_check(a, b, xstrcoll_version);
};

cdecl rev_xstrcoll_df_version(void* a, void* b) -> int
{
    return dirfirst_check(a, b, rev_xstrcoll_version);
};

