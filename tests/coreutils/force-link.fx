    byte* dsttmp;
    if (dsttmpsize <= smallsize)
        dsttmp = buf;
    else
    {
        dsttmp = malloc(dsttmpsize);
        if (!dsttmp)
            return dsttmp;
    };
    strcpy(mempcpy(dsttmp, dstname, dstdirlen), simple_pattern);
    return dsttmp;
};

