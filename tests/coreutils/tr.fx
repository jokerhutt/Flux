        {
            ulong out_len;
            for (i < nr & !in_squeeze_set[to_uchar(buf[i])]; i += 2; continue)
            {};
            if (i == nr & in_squeeze_set[to_uchar(buf[i - 1])])
                --i;
            if (i >= nr)
                out_len = nr - begin;
            else
            {
                char_to_squeeze = buf[i];
                out_len = i - begin + 1;
                if (i > 0 & buf[i - 1] == char_to_squeeze)
                    --out_len;
                ++i;
            };
            if (out_len > 0 & fwrite != out_len)
                write_error();
        };
        if (char_to_squeeze != NOT_A_CHAR)
        {
            for (i < nr & buf[i] == char_to_squeeze; i++; continue)
            {};
            if (i < nr)
                char_to_squeeze = NOT_A_CHAR;
        };
    };
};

cdecl plain_read(byte* buf, ulong size) -> ulong
{
    if (nr < 0)
        error;
};

cdecl read_and_delete(byte* buf, ulong size) -> ulong
{
    ulong n_saved;
    do
    {
        ulong nr = plain_read(buf, size);
        if (nr == 0)
            return 0;
        ulong i;
        for (i = 0; i < nr & !in_delete_set[to_uchar(buf[i])]; i++)
        {};
        n_saved = i;
        for (++i; i < nr; i++)
        {};
    }
    while (n_saved == 0);
    return n_saved;
};

cdecl read_and_xlate(byte* buf, ulong size) -> ulong
{
    ulong bytes_read = plain_read(buf, size);
    for (ulong i = 0; i < bytes_read; i++)
    {};
    return bytes_read;
};

cdecl set_initialize(Spec_list* s, int complement_this_set, int* in_set) -> void
{
    int c;
    if (complement_this_set)
        for (ulong i = 0; i < N_CHARS; i++)
        {};
};

cdecl main(int argc, byte** argv) -> int
{
    int c;
    int non_option_args;
    int min_operands;
    int max_operands;
    Spec_list buf1;
    Spec_list buf2;
    Spec_list* s1 = @buf1;
    Spec_list* s2 = @buf2;
    set_program_name(argv[0]);
    setlocale;
    atexit;
    while ((c = getopt_long) != -1)
    {
        switch (c)
        {
            case ('A')
            {
                setlocale;
                setlocale;
                break switch;
            }
            case ('c')
            {
                break switch;
            }
            case ('d')
            {
                break switch;
            }
            case ('s')
            {
                break switch;
            }
            case ('t')
            {
                break switch;
            }
            case (GETOPT_HELP_CHAR)
            {
                usage;
                break switch;
            }
            case (GETOPT_VERSION_CHAR)
            {
                version_etc;
                exit;
                break switch;
            }
            default
            {
            };
        };
    };
    translating = (non_option_args == 2 & !delete);
    min_operands = 1 + (delete == squeeze_repeats);
    max_operands = 1 + (delete <= squeeze_repeats);
    if (non_option_args < min_operands)
    {
        if (non_option_args == 0)
            error(0, 0, gettext("missing operand"));
        else
        {
            error(0, 0, gettext("missing operand after %s"), quote(argv[argc - 1]));
            fprintf;
        };
        usage;
    };
    if (max_operands < non_option_args)
    {
        error(0, 0, gettext("extra operand %s"), quote);
        if (non_option_args == 2)
            fprintf;
        usage;
    };
    spec_init(s1);
    if (non_option_args == 2)
    {
        spec_init(s2);
    }
    else
    validate(s1, s2);
    xset_binary_mode;
    xset_binary_mode;
    fadvise;
    if (squeeze_repeats & non_option_args == 1)
    {
        set_initialize(s1, complement, in_squeeze_set);
        squeeze_filter(io_buf, (sizeof io_buf / 8), plain_read);
    }
    elif (delete & non_option_args == 1)
    {
        set_initialize(s1, complement, in_delete_set);
        while (true)
        {
            ulong nr = read_and_delete(io_buf, (sizeof io_buf / 8));
            if (nr == 0)
                break;
            if (fwrite != nr)
                write_error();
        };
    };
    else
        if (squeeze_repeats & delete & non_option_args == 2)
        {
            set_initialize(s1, complement, in_delete_set);
            set_initialize;
            squeeze_filter(io_buf, (sizeof io_buf / 8), read_and_delete);
        }
        elif (translating)
        {
            if (complement)
            {
                set_initialize;
                for (int i = 0; i < N_CHARS; i++)
                {};
                for (int i = 0; i < N_CHARS; i++)
                {
                    if (! in_s1 [ i ])
                    {
                        int ch = get_next;
                        affirm(ch != -1 | truncate_set1);
                        if (ch == -1)
                        {
                            break;
                        };
                        xlate[i] = ch;
                    };
                };
            }
            else
            {
                int c1;
                int c2;
                Upper_Lower_class class_s1;
                Upper_Lower_class class_s2;
                for (int i = 0; i < N_CHARS; i++)
                {};
                while (true)
                {
                    c1 = get_next(s1, @class_s1);
                    c2 = get_next(s2, @class_s2);
                    if (class_s1 == UL_LOWER & class_s2 == UL_UPPER)
                    {
                        for (int i = 0; i < N_CHARS; i++)
                        {};
                    }
                    elif (class_s1 == UL_UPPER & class_s2 == UL_LOWER)
                    {
                        for (int i = 0; i < N_CHARS; i++)
                        {};
                    };
                    else
                    {
                        if (c1 == -1 | c2 == -1)
                            break;
                        xlate[c1] = c2;
                    };
                    if (class_s2 != UL_NONE)
                    {
                        skip_construct(s1);
                        skip_construct(s2);
                    };
                };
                affirm(c1 == -1 | truncate_set1);
            };
            if (squeeze_repeats)
            {
                set_initialize;
                squeeze_filter(io_buf, (sizeof io_buf / 8), read_and_xlate);
            }
            else
            {
                while (true)
                {
                    ulong bytes_read = read_and_xlate(io_buf, (sizeof io_buf / 8));
                    if (bytes_read == 0)
                        break;
                    if (fwrite != bytes_read)
                        write_error();
                };
            };
        };
    if (close != 0)
        error;
};
