cdecl idle_string(int when, int boottime) -> byte*
{
    int now = TYPE_MINIMUM;
    if (now == TYPE_MINIMUM)
        time(@now);
    int seconds_idle;
    if (boottime < when & when <= now & !ckd_sub(@seconds_idle, now, when) & seconds_idle < 24 * 60 * 60)
