cdecl LLVMGetCallSiteAttributeCount(LLVMOpaqueValue* C, uint Idx) -> uint;
cdecl LLVMGetCallSiteAttributes(LLVMOpaqueValue* C, uint Idx, LLVMOpaqueAttributeRef** Attrs) -> void;
cdecl LLVMGetCallSiteEnumAttribute(LLVMOpaqueValue* C, uint Idx, uint KindID) -> LLVMOpaqueAttributeRef*;
cdecl LLVMGetCallSiteStringAttribute(LLVMOpaqueValue* C, uint Idx, byte* K, uint KLen) -> LLVMOpaqueAttributeRef*;
cdecl LLVMRemoveCallSiteEnumAttribute(LLVMOpaqueValue* C, uint Idx, uint KindID) -> void;
cdecl LLVMRemoveCallSiteStringAttribute(LLVMOpaqueValue* C, uint Idx, byte* K, uint KLen) -> void;
