        printf(" %s", result);
        free(result);
    };
    putchar('\n');
    if (include_home_and_shell)
    {
        printf(gettext("Directory: "));
        printf("%-29s", pw.pw_dir);
        printf(gettext("Shell: "));
        printf(" %s", pw.pw_shell);
        putchar('\n');
    };
    if (include_project)
        cat_file(gettext("Project: "), pw.pw_dir, ".project");
    if (include_plan)
        cat_file(gettext("Plan:\n"), pw.pw_dir, ".plan");
    putchar('\n');
    if (ferror(stdout))
        write_error();
};

