///
*
* @}

///

///
*
* @defgroup LLVMCCoreValueUses Usage
*
* This module defines functions that allow you to inspect the uses of a
* LLVMValueRef.
*
* It is possible to obtain an LLVMUseRef for any LLVMValueRef instance.
* Each LLVMUseRef (which corresponds to a llvm::Use instance) holds a
* llvm::User and llvm::Value.
*
* @{

///

///
*
* Obtain the first use of a value.
*
* Uses are obtained in an iterator fashion. First, call this function
* to obtain a reference to the first use. Then, call LLVMGetNextUse()
* on that instance and all subsequently obtained instances until
* LLVMGetNextUse() returns NULL.
*
* @see llvm::Value::use_begin()

///

cdecl LLVMGetFirstUse(LLVMOpaqueValue* Val) -> LLVMOpaqueUse*;
///
*
* Obtain the next use of a value.
*
* This effectively advances the iterator. It returns NULL if you are on
* the final use and no more are available.

///

cdecl LLVMGetNextUse(LLVMOpaqueUse* U) -> LLVMOpaqueUse*;
///
*
* Obtain the user value for a user.
*
* The returned value corresponds to a llvm::User type.
*
* @see llvm::Use::getUser()

///

cdecl LLVMGetUser(LLVMOpaqueUse* U) -> LLVMOpaqueValue*;
///
*
* Obtain the value this use corresponds to.
*
* @see llvm::Use::get().

///

cdecl LLVMGetUsedValue(LLVMOpaqueUse* U) -> LLVMOpaqueValue*;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreValueUser User value
*
* Function in this group pertain to LLVMValueRef instances that descent
* from llvm::User. This includes constants, instructions, and
* operators.
*
* @{

///

///
*
* Obtain an operand at a specific index in a llvm::User value.
*
* @see llvm::User::getOperand()

///

cdecl LLVMGetOperand(LLVMOpaqueValue* Val, uint Index) -> LLVMOpaqueValue*;
///
*
* Obtain the use of an operand at a specific index in a llvm::User value.
*
* @see llvm::User::getOperandUse()

///

cdecl LLVMGetOperandUse(LLVMOpaqueValue* Val, uint Index) -> LLVMOpaqueUse*;
///
*
* Set an operand at a specific index in a llvm::User value.
*
* @see llvm::User::setOperand()

///

cdecl LLVMSetOperand(LLVMOpaqueValue* User, uint Index, LLVMOpaqueValue* Val) -> void;
///
*
* Obtain the number of operands in a llvm::User value.
*
* @see llvm::User::getNumOperands()

///

cdecl LLVMGetNumOperands(LLVMOpaqueValue* Val) -> int;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreValueConstant Constants
*
* This section contains APIs for interacting with LLVMValueRef that
* correspond to llvm::Constant instances.
*
* These functions will work for any LLVMValueRef in the llvm::Constant
* class hierarchy.
*
* @{

///

///
*
* Obtain a constant value referring to the null instance of a type.
*
* @see llvm::Constant::getNullValue()

///

cdecl LLVMConstNull(LLVMOpaqueType* Ty) -> LLVMOpaqueValue*;
///
all zeroes
///

///
*
* Obtain a constant value referring to the instance of a type
* consisting of all ones.
*
* This is only valid for integer types.
*
* @see llvm::Constant::getAllOnesValue()

///

cdecl LLVMConstAllOnes(LLVMOpaqueType* Ty) -> LLVMOpaqueValue*;
///
*
* Obtain a constant value referring to an undefined value of a type.
*
* @see llvm::UndefValue::get()

///

cdecl LLVMGetUndef(LLVMOpaqueType* Ty) -> LLVMOpaqueValue*;
///
*
* Obtain a constant value referring to a poison value of a type.
*
* @see llvm::PoisonValue::get()

///

cdecl LLVMGetPoison(LLVMOpaqueType* Ty) -> LLVMOpaqueValue*;
///
*
* Determine whether a value instance is null.
*
* @see llvm::Constant::isNullValue()

///

cdecl LLVMIsNull(LLVMOpaqueValue* Val) -> int;
///
*
* Obtain a constant that is a constant pointer pointing to NULL for a
* specified type.

///

cdecl LLVMConstPointerNull(LLVMOpaqueType* Ty) -> LLVMOpaqueValue*;
///
*
* @defgroup LLVMCCoreValueConstantScalar Scalar constants
*
* Functions in this group model LLVMValueRef instances that correspond
* to constants referring to scalar types.
*
* For integer types, the LLVMTypeRef parameter should correspond to a
* llvm::IntegerType instance and the returned LLVMValueRef will
* correspond to a llvm::ConstantInt.
*
* For floating point types, the LLVMTypeRef returned corresponds to a
* llvm::ConstantFP.
*
* @{

///

///
*
* Obtain a constant value for an integer type.
*
* The returned value corresponds to a llvm::ConstantInt.
*
* @see llvm::ConstantInt::get()
*
* @param IntTy Integer type to obtain value of.
* @param N The value the returned instance should refer to.
* @param SignExtend Whether to sign extend the produced value.

///

cdecl LLVMConstInt(LLVMOpaqueType* IntTy, ulong N, int SignExtend) -> LLVMOpaqueValue*;
///
*
* Obtain a constant value for an integer of arbitrary precision.
*
* @see llvm::ConstantInt::get()

///

cdecl LLVMConstIntOfArbitraryPrecision(LLVMOpaqueType* IntTy, uint NumWords, ulong* Words) -> LLVMOpaqueValue*;
///
*
* Obtain a constant value for an integer parsed from a string.
*
* A similar API, LLVMConstIntOfStringAndSize is also available. If the
* string's length is available, it is preferred to call that function
* instead.
*
* @see llvm::ConstantInt::get()

///

cdecl LLVMConstIntOfString(LLVMOpaqueType* IntTy, byte* Text, byte Radix) -> LLVMOpaqueValue*;
///
*
* Obtain a constant value for an integer parsed from a string with
* specified length.
*
* @see llvm::ConstantInt::get()

///

cdecl LLVMConstIntOfStringAndSize(LLVMOpaqueType* IntTy, byte* Text, uint SLen, byte Radix) -> LLVMOpaqueValue*;
///
*
* Obtain a constant value for a byte type.
*
* The returned value corresponds to a llvm::ConstantByte.
*
* @see llvm::ConstantByte::get()
*
* @param ByteTy Byte type to obtain value of.
* @param N The value the returned instance should refer to.

///

cdecl LLVMConstByte(LLVMOpaqueType* ByteTy, ulong N) -> LLVMOpaqueValue*;
///
*
* Obtain a constant value for a byte of arbitrary precision.
*
* @see llvm::ConstantByte::get()

///

cdecl LLVMConstByteOfArbitraryPrecision(LLVMOpaqueType* ByteTy, uint NumWords, ulong* Words) -> LLVMOpaqueValue*;
///
*
* Obtain a constant value for a byte parsed from a string with specified
* length.
* @see llvm::ConstantByte::get()

///

cdecl LLVMConstByteOfStringAndSize(LLVMOpaqueType* ByteTy, byte* Text, ulong SLen, byte Radix) -> LLVMOpaqueValue*;
///
*
* Obtain a constant value referring to a double floating point value.

///

cdecl LLVMConstReal(LLVMOpaqueType* RealTy, double N) -> LLVMOpaqueValue*;
///
*
* Obtain a constant for a floating point value parsed from a string.
*
* A similar API, LLVMConstRealOfStringAndSize is also available. It
* should be used if the input string's length is known.

///

cdecl LLVMConstRealOfString(LLVMOpaqueType* RealTy, byte* Text) -> LLVMOpaqueValue*;
///
*
* Obtain a constant for a floating point value parsed from a string.

///

cdecl LLVMConstRealOfStringAndSize(LLVMOpaqueType* RealTy, byte* Text, uint SLen) -> LLVMOpaqueValue*;
///
*
* Obtain a constant for a floating point value from array of 64 bit values.
* The length of the array N must be ceildiv(bits, 64), where bits is the
* scalar size in bits of the floating-point type.

///

cdecl LLVMConstFPFromBits(LLVMOpaqueType* Ty, ulong* N) -> LLVMOpaqueValue*;
///
*
* Obtain the zero extended value for an integer constant value.
*
* @see llvm::ConstantInt::getZExtValue()

///

cdecl LLVMConstIntGetZExtValue(LLVMOpaqueValue* ConstantVal) -> ulong;
///
*
* Obtain the sign extended value for an integer constant value.
*
* @see llvm::ConstantInt::getSExtValue()

///

cdecl LLVMConstIntGetSExtValue(LLVMOpaqueValue* ConstantVal) -> long;
///
*
* Obtain the zero extended value for a byte constant value.
*
* @see llvm::ConstantByte::getZExtValue()

///

cdecl LLVMConstByteGetZExtValue(LLVMOpaqueValue* ConstantVal) -> ulong;
///
*
* Obtain the sign extended value for a byte constant value.
*
* @see llvm::ConstantByte::getSExtValue()

///

cdecl LLVMConstByteGetSExtValue(LLVMOpaqueValue* ConstantVal) -> long;
///
*
* Obtain the double value for an floating point constant value.
* losesInfo indicates if some precision was lost in the conversion.
*
* @see llvm::ConstantFP::getDoubleValue

///

cdecl LLVMConstRealGetDouble(LLVMOpaqueValue* ConstantVal, int* losesInfo) -> double;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreValueConstantComposite Composite Constants
*
* Functions in this group operate on composite constants.
*
* @{

///

///
*
* Create a ConstantDataSequential and initialize it with a string.
*
* @deprecated LLVMConstStringInContext is deprecated in favor of the API
* accurate LLVMConstStringInContext2
* @see llvm::ConstantDataArray::getString()

///

cdecl LLVMConstStringInContext(LLVMOpaqueContext* C, byte* Str, uint Length, int DontNullTerminate) -> LLVMOpaqueValue*;
///
*
* Create a ConstantDataSequential and initialize it with a string.
*
* @see llvm::ConstantDataArray::getString()

///

cdecl LLVMConstStringInContext2(LLVMOpaqueContext* C, byte* Str, ulong Length, int DontNullTerminate) -> LLVMOpaqueValue*;
///
*
* Create a ConstantDataSequential with string content in the global context.
*
* This is the same as LLVMConstStringInContext except it operates on the
* global context.
*
* @see LLVMConstStringInContext()
* @see llvm::ConstantDataArray::getString()

///

cdecl LLVMConstString(byte* Str, uint Length, int DontNullTerminate) -> LLVMOpaqueValue*;
///
*
* Returns true if the specified constant is an array of i8.
*
* @see ConstantDataSequential::getAsString()

///

cdecl LLVMIsConstantString(LLVMOpaqueValue* c) -> int;
///
*
* Get the given constant data sequential as a string.
*
* @see ConstantDataSequential::getAsString()

///

cdecl LLVMGetAsString(LLVMOpaqueValue* c, ulong* Length) -> byte*;
///
*
* Get the raw, underlying bytes of the given constant data sequential.
*
* This is the same as LLVMGetAsString except it works for all constant data
* sequentials, not just i8 arrays.
*
* @see ConstantDataSequential::getRawDataValues()

///

cdecl LLVMGetRawDataValues(LLVMOpaqueValue* c, ulong* SizeInBytes) -> byte*;
///
*
* Create an anonymous ConstantStruct with the specified values.
*
* @see llvm::ConstantStruct::getAnon()

///

cdecl LLVMConstStructInContext(LLVMOpaqueContext* C, LLVMOpaqueValue** ConstantVals, uint Count, int Packed) -> LLVMOpaqueValue*;
///
*
* Create a ConstantStruct in the global Context.
*
* This is the same as LLVMConstStructInContext except it operates on the
* global Context.
*
* @see LLVMConstStructInContext()

///

cdecl LLVMConstStruct(LLVMOpaqueValue** ConstantVals, uint Count, int Packed) -> LLVMOpaqueValue*;
///
*
* Create a ConstantArray from values.
*
* @deprecated LLVMConstArray is deprecated in favor of the API accurate
* LLVMConstArray2
* @see llvm::ConstantArray::get()

///

cdecl LLVMConstArray(LLVMOpaqueType* ElementTy, LLVMOpaqueValue** ConstantVals, uint Length) -> LLVMOpaqueValue*;
///
*
* Create a ConstantArray from values.
*
* @see llvm::ConstantArray::get()

///

cdecl LLVMConstArray2(LLVMOpaqueType* ElementTy, LLVMOpaqueValue** ConstantVals, ulong Length) -> LLVMOpaqueValue*;
///
*
* Create a ConstantDataArray from raw values.
*
* ElementTy must be one of i8, i16, i32, i64, half, bfloat, float, or double.
* Data points to a contiguous buffer of raw values in the host endianness. The
* element count is inferred from the element type and the data size in bytes.
*
* @see llvm::ConstantDataArray::getRaw()

///

cdecl LLVMConstDataArray(LLVMOpaqueType* ElementTy, byte* Data, ulong SizeInBytes) -> LLVMOpaqueValue*;
///
*
* Create a non-anonymous ConstantStruct from values.
*
* @see llvm::ConstantStruct::get()

///

cdecl LLVMConstNamedStruct(LLVMOpaqueType* StructTy, LLVMOpaqueValue** ConstantVals, uint Count) -> LLVMOpaqueValue*;
///
*
* Get element of a constant aggregate (struct, array or vector) at the
* specified index. Returns null if the index is out of range, or it's not
* possible to determine the element (e.g., because the constant is a
* constant expression.)
*
* @see llvm::Constant::getAggregateElement()

///

cdecl LLVMGetAggregateElement(LLVMOpaqueValue* C, uint Idx) -> LLVMOpaqueValue*;
///
*
* Get an element at specified index as a constant.
*
* @see ConstantDataSequential::getElementAsConstant()

///

cdecl LLVMGetElementAsConstant(LLVMOpaqueValue* C, uint idx) -> LLVMOpaqueValue*;
///
*
* Create a ConstantVector from values.
*
* @see llvm::ConstantVector::get()

///

cdecl LLVMConstVector(LLVMOpaqueValue** ScalarConstantVals, uint Size) -> LLVMOpaqueValue*;
///
*
* Create a ConstantPtrAuth constant with the given values.
*
* @see llvm::ConstantPtrAuth::get()

///

cdecl LLVMConstantPtrAuth(LLVMOpaqueValue* Ptr, LLVMOpaqueValue* Key, LLVMOpaqueValue* Disc, LLVMOpaqueValue* AddrDisc) -> LLVMOpaqueValue*;
///
*
* @}

