             indeed part of a reference; just ignore it.  */ if ( input_reference ) { while ( line_scan < possible_key . start ) if ( * line_scan == '\n' ) { total_line_count ++ ; line_scan ++ ; line_start = line_scan ; SKIP_NON_WHITE ( line_scan , text_buffer -> end ) ; reference_length = line_scan - line_start ; } else line_scan ++ ; if ( line_scan > possible_key . start ) continue ; } /* Ignore the word if an 'Ignore words' table exists and if it is
