*
* Retrieves the name of an intrinsic.
*
* @see llvm::Intrinsic::getName()

///

cdecl LLVMIntrinsicGetName(uint ID, ulong* NameLength) -> byte*;
///
* Deprecated: Use LLVMIntrinsicCopyOverloadedName2 instead.
///

cdecl LLVMIntrinsicCopyOverloadedName(uint ID, LLVMOpaqueType** OverloadTypes, ulong OverloadCount, ulong* NameLength) -> byte*;
///
*
* Copies the name of an overloaded intrinsic identified by a given list of
* overload types.
*
* Unlike LLVMIntrinsicGetName, the caller is responsible for freeing the
* returned string.
*
* This version also supports unnamed types.
*
* @see llvm::Intrinsic::getName()

///

cdecl LLVMIntrinsicCopyOverloadedName2(LLVMOpaqueModule* Mod, uint ID, LLVMOpaqueType** OverloadTypes, ulong OverloadCount, ulong* NameLength) -> byte*;
///
*
* Obtain if the intrinsic identified by the given ID is overloaded.
*
* @see llvm::Intrinsic::isOverloaded()

///

cdecl LLVMIntrinsicIsOverloaded(uint ID) -> int;
///
*
* Obtain the calling function of a function.
*
* The returned value corresponds to the LLVMCallConv enumeration.
*
* @see llvm::Function::getCallingConv()

///

cdecl LLVMGetFunctionCallConv(LLVMOpaqueValue* Fn) -> uint;
///
*
* Set the calling convention of a function.
*
* @see llvm::Function::setCallingConv()
*
* @param Fn Function to operate on
* @param CC LLVMCallConv to set calling convention to

///

cdecl LLVMSetFunctionCallConv(LLVMOpaqueValue* Fn, uint CC) -> void;
///
*
* Obtain the name of the garbage collector to use during code
* generation.
*
* @see llvm::Function::getGC()

///

cdecl LLVMGetGC(LLVMOpaqueValue* Fn) -> byte*;
///
*
* Define the garbage collector to use during code generation.
*
* @see llvm::Function::setGC()

///

cdecl LLVMSetGC(LLVMOpaqueValue* Fn, byte* Name) -> void;
///
*
* Gets the prefix data associated with a function. Only valid on functions, and
* only if LLVMHasPrefixData returns true.
* See https://llvm.org/docs/LangRef.html#prefix-data

///

cdecl LLVMGetPrefixData(LLVMOpaqueValue* Fn) -> LLVMOpaqueValue*;
///
*
* Check if a given function has prefix data. Only valid on functions.
* See https://llvm.org/docs/LangRef.html#prefix-data

///

cdecl LLVMHasPrefixData(LLVMOpaqueValue* Fn) -> int;
///
*
* Sets the prefix data for the function. Only valid on functions.
* See https://llvm.org/docs/LangRef.html#prefix-data

///

cdecl LLVMSetPrefixData(LLVMOpaqueValue* Fn, LLVMOpaqueValue* prefixData) -> void;
///
*
* Gets the prologue data associated with a function. Only valid on functions,
* and only if LLVMHasPrologueData returns true.
* See https://llvm.org/docs/LangRef.html#prologue-data

///

cdecl LLVMGetPrologueData(LLVMOpaqueValue* Fn) -> LLVMOpaqueValue*;
///
*
* Check if a given function has prologue data. Only valid on functions.
* See https://llvm.org/docs/LangRef.html#prologue-data

///

cdecl LLVMHasPrologueData(LLVMOpaqueValue* Fn) -> int;
///
*
* Sets the prologue data for the function. Only valid on functions.
* See https://llvm.org/docs/LangRef.html#prologue-data

///

cdecl LLVMSetPrologueData(LLVMOpaqueValue* Fn, LLVMOpaqueValue* prologueData) -> void;
///
*
* Add an attribute to a function.
*
* @see llvm::Function::addAttribute()

///

cdecl LLVMAddAttributeAtIndex(LLVMOpaqueValue* F, uint Idx, LLVMOpaqueAttributeRef* A) -> void;
cdecl LLVMGetAttributeCountAtIndex(LLVMOpaqueValue* F, uint Idx) -> uint;
cdecl LLVMGetAttributesAtIndex(LLVMOpaqueValue* F, uint Idx, LLVMOpaqueAttributeRef** Attrs) -> void;
cdecl LLVMGetEnumAttributeAtIndex(LLVMOpaqueValue* F, uint Idx, uint KindID) -> LLVMOpaqueAttributeRef*;
cdecl LLVMGetStringAttributeAtIndex(LLVMOpaqueValue* F, uint Idx, byte* K, uint KLen) -> LLVMOpaqueAttributeRef*;
cdecl LLVMRemoveEnumAttributeAtIndex(LLVMOpaqueValue* F, uint Idx, uint KindID) -> void;
cdecl LLVMRemoveStringAttributeAtIndex(LLVMOpaqueValue* F, uint Idx, byte* K, uint KLen) -> void;
///
*
* Add a target-dependent attribute to a function
* @see llvm::AttrBuilder::addAttribute()

///

cdecl LLVMAddTargetDependentFunctionAttr(LLVMOpaqueValue* Fn, byte* A, byte* V) -> void;
///
*
* @defgroup LLVMCCoreValueFunctionParameters Function Parameters
*
* Functions in this group relate to arguments/parameters on functions.
*
* Functions in this group expect LLVMValueRef instances that correspond
* to llvm::Function instances.
*
* @{

///

///
*
* Obtain the number of parameters in a function.
*
* @see llvm::Function::arg_size()

///

cdecl LLVMCountParams(LLVMOpaqueValue* Fn) -> uint;
///
*
* Obtain the parameters in a function.
*
* The takes a pointer to a pre-allocated array of LLVMValueRef that is
* at least LLVMCountParams() long. This array will be filled with
* LLVMValueRef instances which correspond to the parameters the
* function receives. Each LLVMValueRef corresponds to a llvm::Argument
* instance.
*
* @see llvm::Function::arg_begin()

///

cdecl LLVMGetParams(LLVMOpaqueValue* Fn, LLVMOpaqueValue** Params) -> void;
///
*
* Obtain the parameter at the specified index.
*
* Parameters are indexed from 0.
*
* @see llvm::Function::arg_begin()

///

cdecl LLVMGetParam(LLVMOpaqueValue* Fn, uint Index) -> LLVMOpaqueValue*;
///
*
* Obtain the function to which this argument belongs.
*
* Unlike other functions in this group, this one takes an LLVMValueRef
* that corresponds to a llvm::Attribute.
*
* The returned LLVMValueRef is the llvm::Function to which this
* argument belongs.

///

cdecl LLVMGetParamParent(LLVMOpaqueValue* Inst) -> LLVMOpaqueValue*;
///
*
* Obtain the first parameter to a function.
*
* @see llvm::Function::arg_begin()

///

cdecl LLVMGetFirstParam(LLVMOpaqueValue* Fn) -> LLVMOpaqueValue*;
///
*
* Obtain the last parameter to a function.
*
* @see llvm::Function::arg_end()

///

cdecl LLVMGetLastParam(LLVMOpaqueValue* Fn) -> LLVMOpaqueValue*;
///
*
* Obtain the next parameter to a function.
*
* This takes an LLVMValueRef obtained from LLVMGetFirstParam() (which is
* actually a wrapped iterator) and obtains the next parameter from the
* underlying iterator.

///

cdecl LLVMGetNextParam(LLVMOpaqueValue* Arg) -> LLVMOpaqueValue*;
///
*
* Obtain the previous parameter to a function.
*
* This is the opposite of LLVMGetNextParam().

///

cdecl LLVMGetPreviousParam(LLVMOpaqueValue* Arg) -> LLVMOpaqueValue*;
///
*
* Set the alignment for a function parameter.
*
* @see llvm::Argument::addAttr()
* @see llvm::AttrBuilder::addAlignmentAttr()

///

cdecl LLVMSetParamAlignment(LLVMOpaqueValue* Arg, uint Align) -> void;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreValueGlobalIFunc IFuncs
*
* Functions in this group relate to indirect functions.
*
* Functions in this group expect LLVMValueRef instances that correspond
* to llvm::GlobalIFunc instances.
*
* @{

///

///
*
* Add a global indirect function to a module under a specified name.
*
* @see llvm::GlobalIFunc::create()

///

cdecl LLVMAddGlobalIFunc(LLVMOpaqueModule* M, byte* Name, ulong NameLen, LLVMOpaqueType* Ty, uint AddrSpace, LLVMOpaqueValue* Resolver) -> LLVMOpaqueValue*;
///
*
* Obtain a GlobalIFunc value from a Module by its name.
*
* The returned value corresponds to a llvm::GlobalIFunc value.
*
* @see llvm::Module::getNamedIFunc()

///

cdecl LLVMGetNamedGlobalIFunc(LLVMOpaqueModule* M, byte* Name, ulong NameLen) -> LLVMOpaqueValue*;
///
*
* Obtain an iterator to the first GlobalIFunc in a Module.
*
* @see llvm::Module::ifunc_begin()

///

cdecl LLVMGetFirstGlobalIFunc(LLVMOpaqueModule* M) -> LLVMOpaqueValue*;
///
*
* Obtain an iterator to the last GlobalIFunc in a Module.
*
* @see llvm::Module::ifunc_end()

///

cdecl LLVMGetLastGlobalIFunc(LLVMOpaqueModule* M) -> LLVMOpaqueValue*;
///
*
* Advance a GlobalIFunc iterator to the next GlobalIFunc.
*
* Returns NULL if the iterator was already at the end and there are no more
* global aliases.

///

cdecl LLVMGetNextGlobalIFunc(LLVMOpaqueValue* IFunc) -> LLVMOpaqueValue*;
///
*
* Decrement a GlobalIFunc iterator to the previous GlobalIFunc.
*
* Returns NULL if the iterator was already at the beginning and there are
* no previous global aliases.

///

cdecl LLVMGetPreviousGlobalIFunc(LLVMOpaqueValue* IFunc) -> LLVMOpaqueValue*;
///
*
* Retrieves the resolver function associated with this indirect function, or
* NULL if it doesn't not exist.
*
* @see llvm::GlobalIFunc::getResolver()

///

cdecl LLVMGetGlobalIFuncResolver(LLVMOpaqueValue* IFunc) -> LLVMOpaqueValue*;
///
*
* Sets the resolver function associated with this indirect function.
*
* @see llvm::GlobalIFunc::setResolver()

///

cdecl LLVMSetGlobalIFuncResolver(LLVMOpaqueValue* IFunc, LLVMOpaqueValue* Resolver) -> void;
///
*
* Remove a global indirect function from its parent module and delete it.
*
* @see llvm::GlobalIFunc::eraseFromParent()

///

cdecl LLVMEraseGlobalIFunc(LLVMOpaqueValue* IFunc) -> void;
///
*
* Remove a global indirect function from its parent module.
*
* This unlinks the global indirect function from its containing module but
* keeps it alive.
*
* @see llvm::GlobalIFunc::removeFromParent()

///

cdecl LLVMRemoveGlobalIFunc(LLVMOpaqueValue* IFunc) -> void;
///
*
* @}

///

///
*
* @}

///

///
*
* @}

///

///
*
* @}

///

///
*
* @defgroup LLVMCCoreValueMetadata Metadata
*
* @{

///

///
*
* Create an MDString value from a given string value.
*
* The MDString value does not take ownership of the given string, it remains
* the responsibility of the caller to free it.
*
* @see llvm::MDString::get()

///

cdecl LLVMMDStringInContext2(LLVMOpaqueContext* C, byte* Str, ulong SLen) -> LLVMOpaqueMetadata*;
///
*
* Create an MDNode value with the given array of operands.
*
* @see llvm::MDNode::get()

///

cdecl LLVMMDNodeInContext2(LLVMOpaqueContext* C, LLVMOpaqueMetadata** MDs, ulong Count) -> LLVMOpaqueMetadata*;
///
*
* Obtain a Metadata as a Value.

///

cdecl LLVMMetadataAsValue(LLVMOpaqueContext* C, LLVMOpaqueMetadata* MD) -> LLVMOpaqueValue*;
///
*
* Obtain a Value as a Metadata.

///

cdecl LLVMValueAsMetadata(LLVMOpaqueValue* Val) -> LLVMOpaqueMetadata*;
///
*
* Obtain the underlying string from a MDString value.
*
* @param V Instance to obtain string from.
* @param Length Memory address which will hold length of returned string.
* @return String data in MDString.

///

cdecl LLVMGetMDString(LLVMOpaqueValue* V, uint* Length) -> byte*;
///
*
* Obtain the number of operands from an MDNode value.
*
* @param V MDNode to get number of operands from.
* @return Number of operands of the MDNode.

///

cdecl LLVMGetMDNodeNumOperands(LLVMOpaqueValue* V) -> uint;
///
*
* Obtain the given MDNode's operands.
*
* The passed LLVMValueRef pointer should point to enough memory to hold all of
* the operands of the given MDNode (see LLVMGetMDNodeNumOperands) as
* LLVMValueRefs. This memory will be populated with the LLVMValueRefs of the
* MDNode's operands.
*
* @param V MDNode to get the operands from.
* @param Dest Destination array for operands.

///

cdecl LLVMGetMDNodeOperands(LLVMOpaqueValue* V, LLVMOpaqueValue** Dest) -> void;
///
*
* Replace an operand at a specific index in a llvm::MDNode value.
*
* @see llvm::MDNode::replaceOperandWith()

///

cdecl LLVMReplaceMDNodeOperandWith(LLVMOpaqueValue* V, uint Index, LLVMOpaqueMetadata* Replacement) -> void;
///
* Deprecated: Use LLVMMDStringInContext2 instead.
///

cdecl LLVMMDStringInContext(LLVMOpaqueContext* C, byte* Str, uint SLen) -> LLVMOpaqueValue*;
///
* Deprecated: Use LLVMMDStringInContext2 instead.
///

cdecl LLVMMDString(byte* Str, uint SLen) -> LLVMOpaqueValue*;
///
* Deprecated: Use LLVMMDNodeInContext2 instead.
///

cdecl LLVMMDNodeInContext(LLVMOpaqueContext* C, LLVMOpaqueValue** Vals, uint Count) -> LLVMOpaqueValue*;
///
* Deprecated: Use LLVMMDNodeInContext2 instead.
///

cdecl LLVMMDNode(LLVMOpaqueValue** Vals, uint Count) -> LLVMOpaqueValue*;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreOperandBundle Operand Bundles
*
* Functions in this group operate on LLVMOperandBundleRef instances that
* correspond to llvm::OperandBundleDef instances.
*
* @see llvm::OperandBundleDef
*
* @{

///

///
*
* Create a new operand bundle.
*
* Every invocation should be paired with LLVMDisposeOperandBundle() or memory
* will be leaked.
*
* @param Tag Tag name of the operand bundle
* @param TagLen Length of Tag
* @param Args Memory address of an array of bundle operands
* @param NumArgs Length of Args

///

cdecl LLVMCreateOperandBundle(byte* Tag, ulong TagLen, LLVMOpaqueValue** Args, uint NumArgs) -> LLVMOpaqueOperandBundle*;
///
*
* Destroy an operand bundle.
*
* This must be called for every created operand bundle or memory will be
* leaked.

///

cdecl LLVMDisposeOperandBundle(LLVMOpaqueOperandBundle* Bundle) -> void;
///
*
* Obtain the tag of an operand bundle as a string.
*
* @param Bundle Operand bundle to obtain tag of.
* @param Len Out parameter which holds the length of the returned string.
* @return The tag name of Bundle.
* @see OperandBundleDef::getTag()

///

cdecl LLVMGetOperandBundleTag(LLVMOpaqueOperandBundle* Bundle, ulong* Len) -> byte*;
///
*
* Obtain the number of operands for an operand bundle.
*
* @param Bundle Operand bundle to obtain operand count of.
* @return The number of operands.
* @see OperandBundleDef::input_size()

///

cdecl LLVMGetNumOperandBundleArgs(LLVMOpaqueOperandBundle* Bundle) -> uint;
///
*
* Obtain the operand for an operand bundle at the given index.
*
* @param Bundle Operand bundle to obtain operand of.
* @param Index An operand index, must be less than
* LLVMGetNumOperandBundleArgs().
* @return The operand.

///

cdecl LLVMGetOperandBundleArgAtIndex(LLVMOpaqueOperandBundle* Bundle, uint Index) -> LLVMOpaqueValue*;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreValueBasicBlock Basic Block
*
* A basic block represents a single entry single exit section of code.
* Basic blocks contain a list of instructions which form the body of
* the block.
*
* Basic blocks belong to functions. They have the type of label.
*
* Basic blocks are themselves values. However, the C API models them as
* LLVMBasicBlockRef.
*
* @see llvm::BasicBlock
*
* @{

///

///
*
* Convert a basic block instance to a value type.

///

cdecl LLVMBasicBlockAsValue(LLVMOpaqueBasicBlock* BB) -> LLVMOpaqueValue*;
///
*
* Determine whether an LLVMValueRef is itself a basic block.

///

cdecl LLVMValueIsBasicBlock(LLVMOpaqueValue* Val) -> int;
///
*
* Convert an LLVMValueRef to an LLVMBasicBlockRef instance.

///

cdecl LLVMValueAsBasicBlock(LLVMOpaqueValue* Val) -> LLVMOpaqueBasicBlock*;
///
*
* Obtain the string name of a basic block.

///

cdecl LLVMGetBasicBlockName(LLVMOpaqueBasicBlock* BB) -> byte*;
///
*
* Obtain the function to which a basic block belongs.
*
* @see llvm::BasicBlock::getParent()

///

cdecl LLVMGetBasicBlockParent(LLVMOpaqueBasicBlock* BB) -> LLVMOpaqueValue*;
///
*
* Obtain the terminator instruction for a basic block.
*
* If the basic block does not have a terminator (it is not well-formed
* if it doesn't), then NULL is returned.
*
* The returned LLVMValueRef corresponds to an llvm::Instruction.
*
* @see llvm::BasicBlock::getTerminator()

///

cdecl LLVMGetBasicBlockTerminator(LLVMOpaqueBasicBlock* BB) -> LLVMOpaqueValue*;
///
*
* Obtain the number of basic blocks in a function.
*
* @param Fn Function value to operate on.

///

cdecl LLVMCountBasicBlocks(LLVMOpaqueValue* Fn) -> uint;
///
*
* Obtain all of the basic blocks in a function.
*
* This operates on a function value. The BasicBlocks parameter is a
* pointer to a pre-allocated array of LLVMBasicBlockRef of at least
* LLVMCountBasicBlocks() in length. This array is populated with
* LLVMBasicBlockRef instances.

///

cdecl LLVMGetBasicBlocks(LLVMOpaqueValue* Fn, LLVMOpaqueBasicBlock** BasicBlocks) -> void;
///
*
* Obtain the first basic block in a function.
*
* The returned basic block can be used as an iterator. You will likely
* eventually call into LLVMGetNextBasicBlock() with it.
*
* @see llvm::Function::begin()

///

cdecl LLVMGetFirstBasicBlock(LLVMOpaqueValue* Fn) -> LLVMOpaqueBasicBlock*;
///
*
* Obtain the last basic block in a function.
*
* @see llvm::Function::end()

///

cdecl LLVMGetLastBasicBlock(LLVMOpaqueValue* Fn) -> LLVMOpaqueBasicBlock*;
///
*
* Advance a basic block iterator.

///

cdecl LLVMGetNextBasicBlock(LLVMOpaqueBasicBlock* BB) -> LLVMOpaqueBasicBlock*;
///
*
* Go backwards in a basic block iterator.

///

cdecl LLVMGetPreviousBasicBlock(LLVMOpaqueBasicBlock* BB) -> LLVMOpaqueBasicBlock*;
///
*
* Obtain the basic block that corresponds to the entry point of a
* function.
*
* @see llvm::Function::getEntryBlock()

///

cdecl LLVMGetEntryBasicBlock(LLVMOpaqueValue* Fn) -> LLVMOpaqueBasicBlock*;
///
*
* Insert the given basic block after the insertion point of the given builder.
*
* The insertion point must be valid.
*
* @see llvm::Function::BasicBlockListType::insertAfter()

///

cdecl LLVMInsertExistingBasicBlockAfterInsertBlock(LLVMOpaqueBuilder* Builder, LLVMOpaqueBasicBlock* BB) -> void;
///
*
* Append the given basic block to the basic block list of the given function.
*
* @see llvm::Function::BasicBlockListType::push_back()

///

cdecl LLVMAppendExistingBasicBlock(LLVMOpaqueValue* Fn, LLVMOpaqueBasicBlock* BB) -> void;
///
*
* Create a new basic block without inserting it into a function.
*
* @see llvm::BasicBlock::Create()

///

cdecl LLVMCreateBasicBlockInContext(LLVMOpaqueContext* C, byte* Name) -> LLVMOpaqueBasicBlock*;
///
*
* Append a basic block to the end of a function.
*
* @see llvm::BasicBlock::Create()

///

cdecl LLVMAppendBasicBlockInContext(LLVMOpaqueContext* C, LLVMOpaqueValue* Fn, byte* Name) -> LLVMOpaqueBasicBlock*;
///
*
* Append a basic block to the end of a function using the global
* context.
*
* @see llvm::BasicBlock::Create()

///

cdecl LLVMAppendBasicBlock(LLVMOpaqueValue* Fn, byte* Name) -> LLVMOpaqueBasicBlock*;
///
*
* Insert a basic block in a function before another basic block.
*
* The function to add to is determined by the function of the
* passed basic block.
*
* @see llvm::BasicBlock::Create()

///

cdecl LLVMInsertBasicBlockInContext(LLVMOpaqueContext* C, LLVMOpaqueBasicBlock* BB, byte* Name) -> LLVMOpaqueBasicBlock*;
///
*
* Insert a basic block in a function using the global context.
*
* @see llvm::BasicBlock::Create()

///

cdecl LLVMInsertBasicBlock(LLVMOpaqueBasicBlock* InsertBeforeBB, byte* Name) -> LLVMOpaqueBasicBlock*;
///
*
* Remove a basic block from a function and delete it.
*
* This deletes the basic block from its containing function and deletes
* the basic block itself.
*
* @see llvm::BasicBlock::eraseFromParent()

///

cdecl LLVMDeleteBasicBlock(LLVMOpaqueBasicBlock* BB) -> void;
///
*
* Remove a basic block from a function.
*
* This deletes the basic block from its containing function but keep
* the basic block alive.
*
* @see llvm::BasicBlock::removeFromParent()

///

cdecl LLVMRemoveBasicBlockFromParent(LLVMOpaqueBasicBlock* BB) -> void;
///
*
* Move a basic block to before another one.
*
* @see llvm::BasicBlock::moveBefore()

///

cdecl LLVMMoveBasicBlockBefore(LLVMOpaqueBasicBlock* BB, LLVMOpaqueBasicBlock* MovePos) -> void;
///
*
* Move a basic block to after another one.
*
* @see llvm::BasicBlock::moveAfter()

///

cdecl LLVMMoveBasicBlockAfter(LLVMOpaqueBasicBlock* BB, LLVMOpaqueBasicBlock* MovePos) -> void;
///
*
* Obtain the first instruction in a basic block.
*
* The returned LLVMValueRef corresponds to a llvm::Instruction
* instance.

///

cdecl LLVMGetFirstInstruction(LLVMOpaqueBasicBlock* BB) -> LLVMOpaqueValue*;
///
*
* Obtain the last instruction in a basic block.
*
* The returned LLVMValueRef corresponds to an LLVM:Instruction.

///

cdecl LLVMGetLastInstruction(LLVMOpaqueBasicBlock* BB) -> LLVMOpaqueValue*;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreValueInstruction Instructions
*
* Functions in this group relate to the inspection and manipulation of
* individual instructions.
*
* In the C++ API, an instruction is modeled by llvm::Instruction. This
* class has a large number of descendents. llvm::Instruction is a
* llvm::Value and in the C API, instructions are modeled by
* LLVMValueRef.
*
* This group also contains sub-groups which operate on specific
* llvm::Instruction types, e.g. llvm::CallInst.
*
* @{

///

///
*
* Determine whether an instruction has any metadata attached.

///

cdecl LLVMHasMetadata(LLVMOpaqueValue* Val) -> int;
///
*
* Return metadata associated with an instruction value.

///

cdecl LLVMGetMetadata(LLVMOpaqueValue* Val, uint KindID) -> LLVMOpaqueValue*;
///
*
* Set metadata associated with an instruction value.

///

cdecl LLVMSetMetadata(LLVMOpaqueValue* Val, uint KindID, LLVMOpaqueValue* Node) -> void;
///
*
* Returns the metadata associated with an instruction value, but filters out
* all the debug locations.
*
* @see llvm::Instruction::getAllMetadataOtherThanDebugLoc()

///

cdecl LLVMInstructionGetAllMetadataOtherThanDebugLoc(LLVMOpaqueValue* Instr, ulong* NumEntries) -> LLVMOpaqueValueMetadataEntry*;
///
*
* Obtain the basic block to which an instruction belongs.
*
* @see llvm::Instruction::getParent()

///

cdecl LLVMGetInstructionParent(LLVMOpaqueValue* Inst) -> LLVMOpaqueBasicBlock*;
///
*
* Obtain the instruction that occurs after the one specified.
*
* The next instruction will be from the same basic block.
*
* If this is the last instruction in a basic block, NULL will be
* returned.

///

cdecl LLVMGetNextInstruction(LLVMOpaqueValue* Inst) -> LLVMOpaqueValue*;
///
*
* Obtain the instruction that occurred before this one.
*
* If the instruction is the first instruction in a basic block, NULL
* will be returned.

///

cdecl LLVMGetPreviousInstruction(LLVMOpaqueValue* Inst) -> LLVMOpaqueValue*;
///
*
* Remove an instruction.
*
* The instruction specified is removed from its containing building
* block but is kept alive.
*
* @see llvm::Instruction::removeFromParent()

///

cdecl LLVMInstructionRemoveFromParent(LLVMOpaqueValue* Inst) -> void;
///
*
* Remove and delete an instruction.
*
* The instruction specified is removed from its containing building
* block and then deleted.
*
* @see llvm::Instruction::eraseFromParent()

///

cdecl LLVMInstructionEraseFromParent(LLVMOpaqueValue* Inst) -> void;
///
*
* Delete an instruction.
*
* The instruction specified is deleted. It must have previously been
* removed from its containing building block.
*
* @see llvm::Value::deleteValue()

///

cdecl LLVMDeleteInstruction(LLVMOpaqueValue* Inst) -> void;
///
*
* Obtain the code opcode for an individual instruction.
*
* @see llvm::Instruction::getOpCode()

///

cdecl LLVMGetInstructionOpcode(LLVMOpaqueValue* Inst) -> LLVMOpcode;
///
*
* Obtain the predicate of an instruction.
*
* This is only valid for instructions that correspond to llvm::ICmpInst.
*
* @see llvm::ICmpInst::getPredicate()

///

cdecl LLVMGetICmpPredicate(LLVMOpaqueValue* Inst) -> LLVMIntPredicate;
///
*
* Get whether or not an icmp instruction has the samesign flag.
*
* This is only valid for instructions that correspond to llvm::ICmpInst.
*
* @see llvm::ICmpInst::hasSameSign()

///

cdecl LLVMGetICmpSameSign(LLVMOpaqueValue* Inst) -> int;
///
*
* Set the samesign flag on an icmp instruction.
*
* This is only valid for instructions that correspond to llvm::ICmpInst.
*
* @see llvm::ICmpInst::setSameSign()

///

cdecl LLVMSetICmpSameSign(LLVMOpaqueValue* Inst, int SameSign) -> void;
///
*
* Obtain the float predicate of an instruction.
*
* This is only valid for instructions that correspond to llvm::FCmpInst.
*
* @see llvm::FCmpInst::getPredicate()

///

cdecl LLVMGetFCmpPredicate(LLVMOpaqueValue* Inst) -> LLVMRealPredicate;
///
*
* Create a copy of 'this' instruction that is identical in all ways
* except the following:
*   * The instruction has no parent
*   * The instruction has no name
*
* @see llvm::Instruction::clone()

///

cdecl LLVMInstructionClone(LLVMOpaqueValue* Inst) -> LLVMOpaqueValue*;
///
*
* Determine whether an instruction is a terminator. This routine is named to
* be compatible with historical functions that did this by querying the
* underlying C++ type.
