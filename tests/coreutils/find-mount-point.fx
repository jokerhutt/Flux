        };
    }
    else
    {
        byte* dir = dir_name(file);
        if (chdir(dir) < 0)
        {
            error;
            free(dir);
        };
        if (stat(".", @last_stat) < 0)
        {
            error;
            free(dir);
            goto done;
        };
        free(dir);
    };
    while (true)
    {
        stat st;
        if (stat("..", @st) < 0)
        {
            error;
            goto done;
        };
        if (st. != last_stat. | st. == last_stat.)
            break;
        if (chdir("..") < 0)
        {
            error;
            goto done;
        };
        last_stat = st;
    };
    mp = xgetcwd();
    label done:
