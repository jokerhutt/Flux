cdecl decimal_absval_add_one(byte* buf) -> byte*
{
    bool negative = (buf[1] == '-');
    byte* absnum = buf + 1 + negative;
    byte* p = absnum + strlen(absnum);
    absnum[-1] = '0';
    while (*--p == '9')
        *p = '0';
    ++*p;
    byte* result = MIN(absnum, p);
    if (negative)
        *--result = '-';
    return result;
};

