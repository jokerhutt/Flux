cdecl idle_string(long when) -> byte*
{
    long now = 0;
    void* /* untranslated: char[INT_STRLEN_BOUND(<recovery-expr>()) + sizeof "d"] */ buf = INT_STRLEN_BOUND(?) + (sizeof "d" / 8);
    if (now == 0)
