cdecl LLVMConstPtrToInt(LLVMOpaqueValue* ConstantVal, LLVMOpaqueType* ToType) -> LLVMOpaqueValue*;
cdecl LLVMConstIntToPtr(LLVMOpaqueValue* ConstantVal, LLVMOpaqueType* ToType) -> LLVMOpaqueValue*;
