cdecl wc_lines_neon(int fd) -> wc_lines
{
    int endlines = vdupq_n_u8('\n');
    while (true)
    {
        byte* datap;
        while (8192 <= bytes_read)
        {
            for (int i = 0; i < 128; ++i)
            {
                datap += 64;
            };
        };
        byte* end;
    };
};
