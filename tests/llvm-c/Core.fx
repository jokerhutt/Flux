///
*
* @defgroup LLVMCCoreContext Contexts
*
* Contexts are execution states for the core LLVM IR system.
*
* Most types are tied to a context instance. Multiple contexts can
* exist simultaneously. A single context is not thread safe. However,
* different contexts can execute on different threads simultaneously.
*
* @{

///

cdecl{}* LLVMDiagnosticHandler(LLVMOpaqueDiagnosticInfo*, void*) -> void;

cdecl{}* LLVMYieldCallback(LLVMOpaqueContext*, void*) -> void;

///
*
* Create a new context.
*
* Every call to this function should be paired with a call to
* LLVMContextDispose() or the context will leak memory.

///

cdecl LLVMContextCreate() -> LLVMOpaqueContext*;
///
*
* Obtain the global context instance.

///

cdecl LLVMGetGlobalContext() -> LLVMOpaqueContext*;
///
*
* Set the diagnostic handler for this context.

///

cdecl LLVMContextSetDiagnosticHandler(LLVMOpaqueContext* C, def{}*(LLVMOpaqueDiagnosticInfo*, void*) -> void Handler, void* DiagnosticContext) -> void;
///
*
* Get the diagnostic handler of this context.

///

cdecl LLVMContextGetDiagnosticHandler(LLVMOpaqueContext* C) -> def{}*(LLVMOpaqueDiagnosticInfo*, void*) -> void;
///
*
* Get the diagnostic context of this context.

///

cdecl LLVMContextGetDiagnosticContext(LLVMOpaqueContext* C) -> void*;
///
*
* Set the yield callback function for this context.
*
* @see LLVMContext::setYieldCallback()

///

cdecl LLVMContextSetYieldCallback(LLVMOpaqueContext* C, def{}*(LLVMOpaqueContext*, void*) -> void Callback, void* OpaqueHandle) -> void;
///
*
* Retrieve whether the given context is set to discard all value names.
*
* @see LLVMContext::shouldDiscardValueNames()

///

cdecl LLVMContextShouldDiscardValueNames(LLVMOpaqueContext* C) -> int;
///
*
* Set whether the given context discards all value names.
*
* If true, only the names of GlobalValue objects will be available in the IR.
* This can be used to save memory and runtime, especially in release mode.
*
* @see LLVMContext::setDiscardValueNames()

///

cdecl LLVMContextSetDiscardValueNames(LLVMOpaqueContext* C, int Discard) -> void;
///
*
* Destroy a context instance.
*
* This should be called for every call to LLVMContextCreate() or memory
* will be leaked.

///

cdecl LLVMContextDispose(LLVMOpaqueContext* C) -> void;
