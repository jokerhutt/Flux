cdecl align_nstrftime(byte* buf, ulong size, int recent, tm* tm, int tz, int ns) -> long
{
    byte* nfmt = (? ? abformat[?][tm.tm_mon] : long_time_format[?]);
    return nstrftime(buf, size, nfmt, tm, ?, ns);
};

cdecl long_time_expected_width() -> int
{
    int width = -1;
    if (width < 0)
    {
        long epoch = 0;
        tm tm;
        byte[1] buf = TIME_STAMP_LEN_MAXIMUM + 1;
        if (localtime_rz(?, @epoch, @tm))
        {
            long len;
            if (len > 0)
                width = mbsnwidth(buf, len, MBSWIDTH_FLAGS);
        };
        if (width < 0)
            width = 0;
    };
    return width;
};

cdecl format_user_or_group(byte* name, ulong id, int width) -> void
{
    if (name)
    {
        int name_width = mbswidth(name, MBSWIDTH_FLAGS);
        int width_gap = name_width < 0 ? 0 : width - name_width;
        int pad = MAX(0, width_gap);
        dired_outstring(name);
        do
            dired_outbyte(' ');
        while (pad--);
    }
    else
        dired_pos += printf("%*ju ", width, id);
};

cdecl format_user(uint u, int width, int stat_ok) -> void
{
    format_user_or_group(!? ? "?" : (? ? ((void*)0) : getuser(u)), u, width);
};

cdecl format_group(uint g, int width, int stat_ok) -> void
{
    format_user_or_group(!? ? "?" : (? ? ((void*)0) : getgroup(g)), g, width);
};

cdecl format_user_or_group_width(byte* name, ulong id) -> int
{
    return (name ? mbswidth(name, MBSWIDTH_FLAGS) : snprintf(((void*)0), 0, "%ju", id));
};

cdecl format_inode(void* /* untranslated: char[INT_BUFSIZE_BOUND(<recovery-expr>())] */ buf, fileinfo* f) -> byte*
{
    return (f & f.stat.st_ino != NOT_AN_INODE_NUMBER ? umaxtostr(f.stat.st_ino, buf) : (byte*)"?");
};

cdecl file_escape(byte* str, int path) -> byte*
{
    byte* esc = xnmalloc(3, strlen(str) + 1);
    byte* p = esc;
    while (*str)
    {
        if (? & ISSLASH(*str))
        {
            *p++ = '/';
            str++;
        }
        elif (RFC3986[to_uchar(*str)])
            *p++ = *str++;
        else
            p += sprintf(p, "%%%02x", to_uchar(*str++));
    };
    *p = '\0';
    return esc;
};

cdecl get_type_indicator(int stat_ok, uint mode, filetype type) -> byte
{
    byte c;
    if (? ? ((((mode)) ? 0) ? (0100000)) : type == normal)
    {
        if (?)
            c = '*';
        else
            c = 0;
    }
    else
    {
        if (? ? ((((mode)) ? 0) ? (0040000)) : type == directory | type == arg_directory)
            c = '/';
        elif (indicator_style == slash)
            c = 0;
        else
            if (? ? ((((mode)) ? 0) ? (0120000)) : type == symbolic_link)
                c = '@';
            elif (? ? ((((mode)) ? 0) ? (0010000)) : type == fifo)
                c = '|';
            else
                if (? ? S_ISSOCK(mode) : type == sock)
                    c = '=';
                elif (? & S_ISDOOR(mode))
                    c = '>';
                else
                    c = 0;
    };
    return c;
};

cdecl length_of_file_name_and_frills(fileinfo* f) -> ulong
{
    ulong len = 0;
    byte buf;
    if (?)
        len += 1 + (format == with_commas ? strlen(umaxtostr(f.stat.st_ino, ?)) : inode_number_width);
    if (?)
        len += 1 + (format == with_commas ? strlen(f.scontext) : scontext_width);
    len += fileinfo_name_width(f);
    if (indicator_style != none)
    {
        byte c = ?(f, f.stat.st_mode, f.filetype);
        len += (c != 0);
    };
    return len;
};

cdecl init_column_info(int max_cols) -> void
{
    int column_info_alloc;
    if (? < ?)
    {
        column_info = xpalloc(column_info, @?, ? - ?, -1, (sizeof * column_info / 8));
        if (?)
            xalloc_die();
        ulong* p;
    };
};

