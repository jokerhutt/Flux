*
* Set the personality function attached to the function.
*
* @see llvm::Function::setPersonalityFn()

///

cdecl LLVMSetPersonalityFn(LLVMOpaqueValue* Fn, LLVMOpaqueValue* PersonalityFn) -> void;
///
*
* Obtain the intrinsic ID number which matches the given function name.
*
* @see llvm::Intrinsic::lookupIntrinsicID()

///

cdecl LLVMLookupIntrinsicID(byte* Name, ulong NameLen) -> uint;
///
*
* Obtain the ID number from a function instance.
*
* @see llvm::Function::getIntrinsicID()

///

cdecl LLVMGetIntrinsicID(LLVMOpaqueValue* Fn) -> uint;
///
*
* Get or insert the declaration of an intrinsic. For overloaded intrinsics,
* overload types must be provided to uniquely identify an overload.
*
* @see llvm::Intrinsic::getOrInsertDeclaration()

///

cdecl LLVMGetIntrinsicDeclaration(LLVMOpaqueModule* Mod, uint ID, LLVMOpaqueType** OverloadTypes, ulong OverloadCount) -> LLVMOpaqueValue*;
///
*
* Retrieves the type of an intrinsic. For overloaded intrinsics, overload
* types must be provided to uniquely identify an overload.
*
* @see llvm::Intrinsic::getType()

///

cdecl LLVMIntrinsicGetType(LLVMOpaqueContext* Ctx, uint ID, LLVMOpaqueType** OverloadTypes, ulong OverloadCount) -> LLVMOpaqueType*;
