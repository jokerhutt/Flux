cdecl print_long_entry(byte* name) -> void
{
    passwd* pw = getpwnam(name);
    printf(gettext("Login name: "));
    printf("%-28s", name);
    printf(gettext("In real life: "));
    if (pw == NULL)
    {
        printf(" %s", gettext("???\n"));
        return void;
    }
    else
    {
        byte* comma = strchr(pw, ',');
        if (comma)
            *comma = '\0';
        byte* result = create_fullname(pw, pw);
        printf(" %s", result);
        free(result);
    };
    putchar('\n');
    if (include_home_and_shell)
    {
        printf(gettext("Directory: "));
        printf("%-29s", pw);
        printf(gettext("Shell: "));
        printf(" %s", pw);
        putchar('\n');
    };
    if (include_project)
        cat_file(gettext("Project: "), pw, ".project");
    if (include_plan)
        cat_file(gettext("Plan:\n"), pw, ".plan");
    putchar('\n');
    if (ferror)
        write_error();
};

