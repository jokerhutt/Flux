            byte end_field = *line;
            *line = '\0';
            if (delimiter != ((void*)0))
                fputs(delimiter, stdout);
            else
                fputc(' ', stdout);
            if (delimiter)
                line += MAX(strlen(delimiter), 1);
            else
            {
                *line = end_field;
            };
        }
        else
        {
            break;
        };
    };
    if (?)
        putchar(line_delim);
    if (ferror(stdout))
        write_error();
};

