   a space-separated list of the integers stored in OS all on one line.  */ static void dired_dump_obstack ( char const * prefix , struct obstack * os ) { size_t n_pos ; n_pos = obstack_object_size ( os ) / sizeof ( dired_pos ) ; if ( n_pos > 0 ) { off_t * pos = obstack_finish ( os ) ; fputs ( prefix , stdout ) ; for ( size_t i = 0 ; i < n_pos ; i ++ ) { intmax_t p = pos [ i ] ; printf ( " %jd" , p ) ; } putchar ( '\n' ) ; } } /* Return the platform birthtime member of the stat structure,
