 with another color-ls version */ "always" , "yes" , "force" , "never" , "no" , "none" , "auto" , "tty" , "if-tty" , NULL } ; static enum when_type const when_types [ ] = { when_always , when_always , when_always , when_never , when_never , when_never , when_if_tty , when_if_tty , when_if_tty } ; ARGMATCH_VERIFY ( when_args , when_types ) ; /* Information about filling a column.  */ struct column_info { bool valid_len ; size_t line_len ; size_t * col_arr ; } ; /* Array with information about column fullness.  */ static struct column_info * column_info ; /* Maximum number of columns ever possible for this display.  */ static size_t max_idx ; /* The minimum width of a non-final column is 3: 1 character for the name
   and 2 for the separating white space.  The final column is not padded.  */ enum { MIN_COLUMN_WIDTH = 3 } ; /* This zero-based index is for the --dired option.  It is incremented
