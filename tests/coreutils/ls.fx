        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -t\n\
         sort by time, newest first; see --time\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -T, --tabsize=COLS\n\
         assume tab stops at each COLS instead of 8\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -u\n\
         with -lt: sort by, and show, access time;\n\
         with -l: show access time and sort by name;\n\
         otherwise: sort by access time, newest first\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -U\n\
         do not sort directory entries\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -v\n\
         natural sort of (version) numbers within text\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -w, --width=COLS\n\
         set output width to COLS.  0 means no limit\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -x\n\
         list entries by lines instead of by columns\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -X\n\
         sort alphabetically by entry extension\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -Z, --context\n\
         print any security context of each file\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
      --zero\n\
         end each output line with NUL, not newline\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("\
  -1\n\
         list one file per line\n\
"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("      --help\n         display this help and exit\n"));
        oputs_((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")), gettext("      --version\n         output version information and exit\n"));
        emit_size_note();
        fputs;
        fputs;
        fputs;
        fputs;
        emit_ancillary_info((ls_mode ? LS_LS ? "ls" : (ls_mode ? LS_MULTI_COL ? "dir" : "vdir")));
    };
    exit(status);
};
