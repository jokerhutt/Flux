"));
        oputs_("numfmt", gettext("\
      --to=UNIT\n\
         auto-scale output numbers to UNITs; see UNIT below\n\
"));
        oputs_("numfmt", gettext("\
      --to-unit=N\n\
         the output unit size (instead of the default 1)\n\
"));
        oputs_("numfmt", gettext("\
