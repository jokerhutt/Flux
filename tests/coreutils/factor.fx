cdecl lbuf_putc(byte c) -> void
{
    lbuf_buf[?++] = c;
};

cdecl lbuf_putnl() -> void
{
    lbuf_putc('\n');
    int line_buffered = -1;
    if (line_buffered < 0)
        line_buffered = isatty(0);
    if (line_buffered)
        lbuf_flush();
    elif (FACTOR_PIPE_BUF <= ?)
        lbuf_half_flush();
};

