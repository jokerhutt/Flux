*
* LLVMGetDataLayout is DEPRECATED, as the name is not only incorrect,
* but match the name of another method on the module. Prefer the use
* of LLVMGetDataLayoutStr, which is not ambiguous.

///

cdecl LLVMGetDataLayoutStr(LLVMOpaqueModule* M) -> byte*;
cdecl LLVMGetDataLayout(LLVMOpaqueModule* M) -> byte*;
///
*
* Set the data layout for a module.
*
* @see Module::setDataLayout()

///

cdecl LLVMSetDataLayout(LLVMOpaqueModule* M, byte* DataLayoutStr) -> void;
///
*
* Obtain the target triple for a module.
*
* @see Module::getTargetTriple()

///

cdecl LLVMGetTarget(LLVMOpaqueModule* M) -> byte*;
///
*
* Set the target triple for a module.
*
* @see Module::setTargetTriple()

///

cdecl LLVMSetTarget(LLVMOpaqueModule* M, byte* Triple) -> void;
///
*
* Returns the module flags as an array of flag-key-value triples.  The caller
* is responsible for freeing this array by calling
* \c LLVMDisposeModuleFlagsMetadata.
*
* @see Module::getModuleFlagsMetadata()

///

cdecl LLVMCopyModuleFlagsMetadata(LLVMOpaqueModule* M, ulong* Len) -> LLVMOpaqueModuleFlagEntry*;
///
*
* Destroys module flags metadata entries.

///

cdecl LLVMDisposeModuleFlagsMetadata(LLVMOpaqueModuleFlagEntry* Entries) -> void;
///
*
* Returns the flag behavior for a module flag entry at a specific index.
*
* @see Module::ModuleFlagEntry::Behavior

///

cdecl LLVMModuleFlagEntriesGetFlagBehavior(LLVMOpaqueModuleFlagEntry* Entries, uint Index) -> LLVMModuleFlagBehavior;
///
*
* Returns the key for a module flag entry at a specific index.
*
* @see Module::ModuleFlagEntry::Key

///

cdecl LLVMModuleFlagEntriesGetKey(LLVMOpaqueModuleFlagEntry* Entries, uint Index, ulong* Len) -> byte*;
///
*
* Returns the metadata for a module flag entry at a specific index.
*
* @see Module::ModuleFlagEntry::Val

///

cdecl LLVMModuleFlagEntriesGetMetadata(LLVMOpaqueModuleFlagEntry* Entries, uint Index) -> LLVMOpaqueMetadata*;
///
*
* Add a module-level flag to the module-level flags metadata if it doesn't
* already exist.
*
* @see Module::getModuleFlag()

///

cdecl LLVMGetModuleFlag(LLVMOpaqueModule* M, byte* Key, ulong KeyLen) -> LLVMOpaqueMetadata*;
///
*
* Add a module-level flag to the module-level flags metadata if it doesn't
* already exist.
*
* @see Module::addModuleFlag()

///

cdecl LLVMAddModuleFlag(LLVMOpaqueModule* M, LLVMModuleFlagBehavior Behavior, byte* Key, ulong KeyLen, LLVMOpaqueMetadata* Val) -> void;
///
*
* Dump a representation of a module to stderr.
*
* @see Module::dump()

///

cdecl LLVMDumpModule(LLVMOpaqueModule* M) -> void;
///
*
* Print a representation of a module to a file. The ErrorMessage needs to be
* disposed with LLVMDisposeMessage. Returns 0 on success, 1 otherwise.
*
* @see Module::print()

///

cdecl LLVMPrintModuleToFile(LLVMOpaqueModule* M, byte* Filename, byte** ErrorMessage) -> int;
///
*
* Return a string representation of the module. Use
* LLVMDisposeMessage to free the string.
*
* @see Module::print()

///

cdecl LLVMPrintModuleToString(LLVMOpaqueModule* M) -> byte*;
///
*
* Get inline assembly for a module.
*
* @see Module::getModuleInlineAsm()

///

cdecl LLVMGetModuleInlineAsm(LLVMOpaqueModule* M, ulong* Len) -> byte*;
///
*
* Set inline assembly for a module.
*
* @see Module::setModuleInlineAsm()

///

cdecl LLVMSetModuleInlineAsm2(LLVMOpaqueModule* M, byte* Asm, ulong Len) -> void;
///
*
* Append inline assembly to a module.
*
* @see Module::appendModuleInlineAsm()

///

cdecl LLVMAppendModuleInlineAsm(LLVMOpaqueModule* M, byte* Asm, ulong Len) -> void;
///
*
* Create the specified uniqued inline asm string.
*
* @see InlineAsm::get()

///

cdecl LLVMGetInlineAsm(LLVMOpaqueType* Ty, byte* AsmString, ulong AsmStringSize, byte* Constraints, ulong ConstraintsSize, int HasSideEffects, int IsAlignStack, LLVMInlineAsmDialect Dialect, int CanThrow) -> LLVMOpaqueValue*;
///
*
* Get the template string used for an inline assembly snippet
*

///

cdecl LLVMGetInlineAsmAsmString(LLVMOpaqueValue* InlineAsmVal, ulong* Len) -> byte*;
///
*
* Get the raw constraint string for an inline assembly snippet
*

///

cdecl LLVMGetInlineAsmConstraintString(LLVMOpaqueValue* InlineAsmVal, ulong* Len) -> byte*;
///
*
* Get the dialect used by the inline asm snippet
*

///

cdecl LLVMGetInlineAsmDialect(LLVMOpaqueValue* InlineAsmVal) -> LLVMInlineAsmDialect;
///
*
* Get the function type of the inline assembly snippet. The same type that
* was passed into LLVMGetInlineAsm originally
*
* @see LLVMGetInlineAsm
*

///

cdecl LLVMGetInlineAsmFunctionType(LLVMOpaqueValue* InlineAsmVal) -> LLVMOpaqueType*;
///
*
* Get if the inline asm snippet has side effects
*

///

cdecl LLVMGetInlineAsmHasSideEffects(LLVMOpaqueValue* InlineAsmVal) -> int;
///
*
* Get if the inline asm snippet needs an aligned stack
*

///

cdecl LLVMGetInlineAsmNeedsAlignedStack(LLVMOpaqueValue* InlineAsmVal) -> int;
///
*
* Get if the inline asm snippet may unwind the stack
*

///

cdecl LLVMGetInlineAsmCanUnwind(LLVMOpaqueValue* InlineAsmVal) -> int;
///
*
* Obtain the context to which this module is associated.
*
* @see Module::getContext()

///

cdecl LLVMGetModuleContext(LLVMOpaqueModule* M) -> LLVMOpaqueContext*;
///
* Deprecated: Use LLVMGetTypeByName2 instead.
///

cdecl LLVMGetTypeByName(LLVMOpaqueModule* M, byte* Name) -> LLVMOpaqueType*;
///
*
* Obtain an iterator to the first NamedMDNode in a Module.
*
* @see llvm::Module::named_metadata_begin()

///

cdecl LLVMGetFirstNamedMetadata(LLVMOpaqueModule* M) -> LLVMOpaqueNamedMDNode*;
///
*
* Obtain an iterator to the last NamedMDNode in a Module.
*
* @see llvm::Module::named_metadata_end()

///

cdecl LLVMGetLastNamedMetadata(LLVMOpaqueModule* M) -> LLVMOpaqueNamedMDNode*;
///
*
* Advance a NamedMDNode iterator to the next NamedMDNode.
*
* Returns NULL if the iterator was already at the end and there are no more
* named metadata nodes.

///

cdecl LLVMGetNextNamedMetadata(LLVMOpaqueNamedMDNode* NamedMDNode) -> LLVMOpaqueNamedMDNode*;
///
*
* Decrement a NamedMDNode iterator to the previous NamedMDNode.
*
* Returns NULL if the iterator was already at the beginning and there are
* no previous named metadata nodes.

///

cdecl LLVMGetPreviousNamedMetadata(LLVMOpaqueNamedMDNode* NamedMDNode) -> LLVMOpaqueNamedMDNode*;
///
*
* Retrieve a NamedMDNode with the given name, returning NULL if no such
* node exists.
*
* @see llvm::Module::getNamedMetadata()

///

cdecl LLVMGetNamedMetadata(LLVMOpaqueModule* M, byte* Name, ulong NameLen) -> LLVMOpaqueNamedMDNode*;
///
*
* Retrieve a NamedMDNode with the given name, creating a new node if no such
* node exists.
*
* @see llvm::Module::getOrInsertNamedMetadata()

///

cdecl LLVMGetOrInsertNamedMetadata(LLVMOpaqueModule* M, byte* Name, ulong NameLen) -> LLVMOpaqueNamedMDNode*;
///
*
* Retrieve the name of a NamedMDNode.
*
* @see llvm::NamedMDNode::getName()

///

cdecl LLVMGetNamedMetadataName(LLVMOpaqueNamedMDNode* NamedMD, ulong* NameLen) -> byte*;
///
*
* Obtain the number of operands for named metadata in a module.
*
* @see llvm::Module::getNamedMetadata()

///

cdecl LLVMGetNamedMetadataNumOperands(LLVMOpaqueModule* M, byte* Name) -> uint;
///
*
* Obtain the named metadata operands for a module.
*
* The passed LLVMValueRef pointer should refer to an array of
* LLVMValueRef at least LLVMGetNamedMetadataNumOperands long. This
* array will be populated with the LLVMValueRef instances. Each
* instance corresponds to a llvm::MDNode.
*
* @see llvm::Module::getNamedMetadata()
* @see llvm::MDNode::getOperand()

///

cdecl LLVMGetNamedMetadataOperands(LLVMOpaqueModule* M, byte* Name, LLVMOpaqueValue** Dest) -> void;
///
*
* Add an operand to named metadata.
*
* @see llvm::Module::getNamedMetadata()
* @see llvm::MDNode::addOperand()

///

cdecl LLVMAddNamedMetadataOperand(LLVMOpaqueModule* M, byte* Name, LLVMOpaqueValue* Val) -> void;
///
*
* Return the directory of the debug location for this value, which must be
* an llvm::Instruction, llvm::GlobalVariable, or llvm::Function.
*
* @see llvm::Instruction::getDebugLoc()
* @see llvm::GlobalVariable::getDebugInfo()
* @see llvm::Function::getSubprogram()

///

cdecl LLVMGetDebugLocDirectory(LLVMOpaqueValue* Val, uint* Length) -> byte*;
///
*
* Return the filename of the debug location for this value, which must be
* an llvm::Instruction, llvm::GlobalVariable, or llvm::Function.
*
* @see llvm::Instruction::getDebugLoc()
* @see llvm::GlobalVariable::getDebugInfo()
* @see llvm::Function::getSubprogram()

///

cdecl LLVMGetDebugLocFilename(LLVMOpaqueValue* Val, uint* Length) -> byte*;
///
*
* Return the line number of the debug location for this value, which must be
* an llvm::Instruction, llvm::GlobalVariable, or llvm::Function.
*
* @see llvm::Instruction::getDebugLoc()
* @see llvm::GlobalVariable::getDebugInfo()
* @see llvm::Function::getSubprogram()

///

cdecl LLVMGetDebugLocLine(LLVMOpaqueValue* Val) -> uint;
///
*
* Return the column number of the debug location for this value, which must be
* an llvm::Instruction.
*
* @see llvm::Instruction::getDebugLoc()

///

cdecl LLVMGetDebugLocColumn(LLVMOpaqueValue* Val) -> uint;
///
*
* Add a function to a module under a specified name.
*
* @see llvm::Function::Create()

///

cdecl LLVMAddFunction(LLVMOpaqueModule* M, byte* Name, LLVMOpaqueType* FunctionTy) -> LLVMOpaqueValue*;
///
*
* Obtain or insert a function into a module.
*
* If a function with the specified name already exists in the module, it
* is returned. Otherwise, a new function is created in the module with the
* specified name and type and is returned.
*
* The returned value corresponds to a llvm::Function instance.
*
* @see llvm::Module::getOrInsertFunction()

///

cdecl LLVMGetOrInsertFunction(LLVMOpaqueModule* M, byte* Name, ulong NameLen, LLVMOpaqueType* FunctionTy) -> LLVMOpaqueValue*;
///
*
* Obtain a Function value from a Module by its name.
*
* The returned value corresponds to a llvm::Function value.
*
* @see llvm::Module::getFunction()

///

cdecl LLVMGetNamedFunction(LLVMOpaqueModule* M, byte* Name) -> LLVMOpaqueValue*;
///
*
* Obtain a Function value from a Module by its name.
*
* The returned value corresponds to a llvm::Function value.
*
* @see llvm::Module::getFunction()

///

cdecl LLVMGetNamedFunctionWithLength(LLVMOpaqueModule* M, byte* Name, ulong Length) -> LLVMOpaqueValue*;
///
*
* Obtain an iterator to the first Function in a Module.
*
* @see llvm::Module::begin()

///

cdecl LLVMGetFirstFunction(LLVMOpaqueModule* M) -> LLVMOpaqueValue*;
///
*
* Obtain an iterator to the last Function in a Module.
*
* @see llvm::Module::end()

///

cdecl LLVMGetLastFunction(LLVMOpaqueModule* M) -> LLVMOpaqueValue*;
///
*
* Advance a Function iterator to the next Function.
*
* Returns NULL if the iterator was already at the end and there are no more
* functions.

///

cdecl LLVMGetNextFunction(LLVMOpaqueValue* Fn) -> LLVMOpaqueValue*;
///
*
* Decrement a Function iterator to the previous Function.
*
* Returns NULL if the iterator was already at the beginning and there are
* no previous functions.

///

cdecl LLVMGetPreviousFunction(LLVMOpaqueValue* Fn) -> LLVMOpaqueValue*;
///
* Deprecated: Use LLVMSetModuleInlineAsm2 instead.
///

cdecl LLVMSetModuleInlineAsm(LLVMOpaqueModule* M, byte* Asm) -> void;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreType Types
*
* Types represent the type of a value.
*
* Types are associated with a context instance. The context internally
* deduplicates types so there is only 1 instance of a specific type
* alive at a time. In other words, a unique type is shared among all
* consumers within a context.
*
* A Type in the C API corresponds to llvm::Type.
*
* Types have the following hierarchy:
*
*   types:
*     integer type
*     byte type
*     real type
*     function type
*     sequence types:
*       array type
*       pointer type
*       vector type
*     void type
*     label type
*     opaque type
*
* @{

///

///
*
* Obtain the enumerated type of a Type instance.
*
* @see llvm::Type:getTypeID()

///

cdecl LLVMGetTypeKind(LLVMOpaqueType* Ty) -> LLVMTypeKind;
///
*
* Whether the type has a known size.
*
* Things that don't have a size are abstract types, labels, and void.a
*
* @see llvm::Type::isSized()

///

cdecl LLVMTypeIsSized(LLVMOpaqueType* Ty) -> int;
///
*
* Obtain the context to which this type instance is associated.
*
* @see llvm::Type::getContext()

///

cdecl LLVMGetTypeContext(LLVMOpaqueType* Ty) -> LLVMOpaqueContext*;
///
*
* Dump a representation of a type to stderr.
*
* @see llvm::Type::dump()

///

cdecl LLVMDumpType(LLVMOpaqueType* Val) -> void;
///
*
* Return a string representation of the type. Use
* LLVMDisposeMessage to free the string.
*
* @see llvm::Type::print()

///

cdecl LLVMPrintTypeToString(LLVMOpaqueType* Val) -> byte*;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreTypeByte Byte Types
*
* Functions in this section operate on byte types.
*
* @{

///

///
*
* Obtain a byte type from a context with specified bit width.

///

cdecl LLVMByteTypeInContext(LLVMOpaqueContext* C, uint NumBits) -> LLVMOpaqueType*;
cdecl LLVMGetByteTypeWidth(LLVMOpaqueType* ByteTy) -> uint;
///
*
* @defgroup LLVMCCoreTypeInt Integer Types
*
* Functions in this section operate on integer types.
*
* @{

///

///
*
* Obtain an integer type from a context with specified bit width.

///

cdecl LLVMInt1TypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
cdecl LLVMInt8TypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
cdecl LLVMInt16TypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
cdecl LLVMInt32TypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
cdecl LLVMInt64TypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
cdecl LLVMInt128TypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
cdecl LLVMIntTypeInContext(LLVMOpaqueContext* C, uint NumBits) -> LLVMOpaqueType*;
///
*
* Obtain an integer type from the global context with a specified bit
* width.

///

cdecl LLVMInt1Type() -> LLVMOpaqueType*;
cdecl LLVMInt8Type() -> LLVMOpaqueType*;
cdecl LLVMInt16Type() -> LLVMOpaqueType*;
cdecl LLVMInt32Type() -> LLVMOpaqueType*;
cdecl LLVMInt64Type() -> LLVMOpaqueType*;
cdecl LLVMInt128Type() -> LLVMOpaqueType*;
cdecl LLVMIntType(uint NumBits) -> LLVMOpaqueType*;
cdecl LLVMGetIntTypeWidth(LLVMOpaqueType* IntegerTy) -> uint;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreTypeFloat Floating Point Types
*
* @{

///

///
*
* Obtain a 16-bit floating point type from a context.

///

cdecl LLVMHalfTypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
///
*
* Obtain a 16-bit brain floating point type from a context.

///

cdecl LLVMBFloatTypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
///
*
* Obtain a 32-bit floating point type from a context.

///

cdecl LLVMFloatTypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
///
*
* Obtain a 64-bit floating point type from a context.

///

cdecl LLVMDoubleTypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
///
*
* Obtain a 80-bit floating point type (X87) from a context.

///

cdecl LLVMX86FP80TypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
///
*
* Obtain a 128-bit floating point type (112-bit mantissa) from a
* context.

///

cdecl LLVMFP128TypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
///
*
* Obtain a 128-bit floating point type (two 64-bits) from a context.

///

cdecl LLVMPPCFP128TypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
///
*
* Obtain a floating point type from the global context.
*
* These map to the functions in this group of the same name.

///

cdecl LLVMHalfType() -> LLVMOpaqueType*;
cdecl LLVMBFloatType() -> LLVMOpaqueType*;
cdecl LLVMFloatType() -> LLVMOpaqueType*;
cdecl LLVMDoubleType() -> LLVMOpaqueType*;
cdecl LLVMX86FP80Type() -> LLVMOpaqueType*;
cdecl LLVMFP128Type() -> LLVMOpaqueType*;
cdecl LLVMPPCFP128Type() -> LLVMOpaqueType*;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreTypeFunction Function Types
*
* @{

///

///
*
* Obtain a function type consisting of a specified signature.
*
* The function is defined as a tuple of a return Type, a list of
* parameter types, and whether the function is variadic.

///

cdecl LLVMFunctionType(LLVMOpaqueType* ReturnType, LLVMOpaqueType** ParamTypes, uint ParamCount, int IsVarArg) -> LLVMOpaqueType*;
///
*
* Returns whether a function type is variadic.

///

cdecl LLVMIsFunctionVarArg(LLVMOpaqueType* FunctionTy) -> int;
///
*
* Obtain the Type this function Type returns.

///

cdecl LLVMGetReturnType(LLVMOpaqueType* FunctionTy) -> LLVMOpaqueType*;
///
*
* Obtain the number of parameters this function accepts.

///

cdecl LLVMCountParamTypes(LLVMOpaqueType* FunctionTy) -> uint;
///
*
* Obtain the types of a function's parameters.
*
* The Dest parameter should point to a pre-allocated array of
* LLVMTypeRef at least LLVMCountParamTypes() large. On return, the
* first LLVMCountParamTypes() entries in the array will be populated
* with LLVMTypeRef instances.
*
* @param FunctionTy The function type to operate on.
* @param Dest Memory address of an array to be filled with result.

///

cdecl LLVMGetParamTypes(LLVMOpaqueType* FunctionTy, LLVMOpaqueType** Dest) -> void;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreTypeStruct Structure Types
*
* These functions relate to LLVMTypeRef instances.
*
* @see llvm::StructType
*
* @{

///

///
*
* Create a new structure type in a context.
*
* A structure is specified by a list of inner elements/types and
* whether these can be packed together.
*
* @see llvm::StructType::create()

///

cdecl LLVMStructTypeInContext(LLVMOpaqueContext* C, LLVMOpaqueType** ElementTypes, uint ElementCount, int Packed) -> LLVMOpaqueType*;
///
*
* Create a new structure type in the global context.
*
* @see llvm::StructType::create()

///

cdecl LLVMStructType(LLVMOpaqueType** ElementTypes, uint ElementCount, int Packed) -> LLVMOpaqueType*;
///
*
* Create an empty structure in a context having a specified name.
*
* @see llvm::StructType::create()

///

cdecl LLVMStructCreateNamed(LLVMOpaqueContext* C, byte* Name) -> LLVMOpaqueType*;
///
*
* Obtain the name of a structure.
*
* @see llvm::StructType::getName()

///

cdecl LLVMGetStructName(LLVMOpaqueType* Ty) -> byte*;
///
*
* Set the contents of a structure type.
*
* @see llvm::StructType::setBody()

///

cdecl LLVMStructSetBody(LLVMOpaqueType* StructTy, LLVMOpaqueType** ElementTypes, uint ElementCount, int Packed) -> void;
///
*
* Get the number of elements defined inside the structure.
*
* @see llvm::StructType::getNumElements()

///

cdecl LLVMCountStructElementTypes(LLVMOpaqueType* StructTy) -> uint;
///
*
* Get the elements within a structure.
*
* The function is passed the address of a pre-allocated array of
* LLVMTypeRef at least LLVMCountStructElementTypes() long. After
* invocation, this array will be populated with the structure's
* elements. The objects in the destination array will have a lifetime
* of the structure type itself, which is the lifetime of the context it
* is contained in.

///

cdecl LLVMGetStructElementTypes(LLVMOpaqueType* StructTy, LLVMOpaqueType** Dest) -> void;
///
*
* Get the type of the element at a given index in the structure.
*
* @see llvm::StructType::getTypeAtIndex()

///

cdecl LLVMStructGetTypeAtIndex(LLVMOpaqueType* StructTy, uint i) -> LLVMOpaqueType*;
///
*
* Determine whether a structure is packed.
*
* @see llvm::StructType::isPacked()

///

cdecl LLVMIsPackedStruct(LLVMOpaqueType* StructTy) -> int;
///
*
* Determine whether a structure is opaque.
*
* @see llvm::StructType::isOpaque()

///

cdecl LLVMIsOpaqueStruct(LLVMOpaqueType* StructTy) -> int;
///
*
* Determine whether a structure is literal.
*
* @see llvm::StructType::isLiteral()

///

cdecl LLVMIsLiteralStruct(LLVMOpaqueType* StructTy) -> int;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreTypeSequential Sequential Types
*
* Sequential types represents "arrays" of types. This is a super class
* for array, vector, and pointer types.
*
* @{

///

///
*
* Obtain the element type of an array or vector type.
*
* @see llvm::SequentialType::getElementType()

///

cdecl LLVMGetElementType(LLVMOpaqueType* Ty) -> LLVMOpaqueType*;
///
*
* Returns type's subtypes
*
* @see llvm::Type::subtypes()

///

cdecl LLVMGetSubtypes(LLVMOpaqueType* Tp, LLVMOpaqueType** Arr) -> void;
///
*
*  Return the number of types in the derived type.
*
* @see llvm::Type::getNumContainedTypes()

///

cdecl LLVMGetNumContainedTypes(LLVMOpaqueType* Tp) -> uint;
///
*
* Create a fixed size array type that refers to a specific type.
*
* The created type will exist in the context that its element type
* exists in.
*
* @deprecated LLVMArrayType is deprecated in favor of the API accurate
* LLVMArrayType2
* @see llvm::ArrayType::get()

///

cdecl LLVMArrayType(LLVMOpaqueType* ElementType, uint ElementCount) -> LLVMOpaqueType*;
///
*
* Create a fixed size array type that refers to a specific type.
*
* The created type will exist in the context that its element type
* exists in.
*
* @see llvm::ArrayType::get()

///

cdecl LLVMArrayType2(LLVMOpaqueType* ElementType, ulong ElementCount) -> LLVMOpaqueType*;
///
*
* Obtain the length of an array type.
*
* This only works on types that represent arrays.
*
* @deprecated LLVMGetArrayLength is deprecated in favor of the API accurate
* LLVMGetArrayLength2
* @see llvm::ArrayType::getNumElements()

///

cdecl LLVMGetArrayLength(LLVMOpaqueType* ArrayTy) -> uint;
///
*
* Obtain the length of an array type.
*
* This only works on types that represent arrays.
*
* @see llvm::ArrayType::getNumElements()

///

cdecl LLVMGetArrayLength2(LLVMOpaqueType* ArrayTy) -> ulong;
///
*
* Create a pointer type that points to a defined type.
*
* The created type will exist in the context that its pointee type
* exists in.
*
* @see llvm::PointerType::get()

///

cdecl LLVMPointerType(LLVMOpaqueType* ElementType, uint AddressSpace) -> LLVMOpaqueType*;
///
*
* Determine whether a pointer is opaque.
*
* True if this is an instance of an opaque PointerType.
*
* @see llvm::Type::isOpaquePointerTy()

///

cdecl LLVMPointerTypeIsOpaque(LLVMOpaqueType* Ty) -> int;
///
*
* Create an opaque pointer type in a context.
*
* @see llvm::PointerType::get()

///

cdecl LLVMPointerTypeInContext(LLVMOpaqueContext* C, uint AddressSpace) -> LLVMOpaqueType*;
///
*
* Obtain the address space of a pointer type.
*
* This only works on types that represent pointers.
*
* @see llvm::PointerType::getAddressSpace()

///

cdecl LLVMGetPointerAddressSpace(LLVMOpaqueType* PointerTy) -> uint;
///
*
* Create a vector type that contains a defined type and has a specific
* number of elements.
*
* The created type will exist in the context thats its element type
* exists in.
*
* @see llvm::VectorType::get()

///

cdecl LLVMVectorType(LLVMOpaqueType* ElementType, uint ElementCount) -> LLVMOpaqueType*;
///
*
* Create a vector type that contains a defined type and has a scalable
* number of elements.
*
* The created type will exist in the context thats its element type
* exists in.
*
* @see llvm::ScalableVectorType::get()

///

cdecl LLVMScalableVectorType(LLVMOpaqueType* ElementType, uint ElementCount) -> LLVMOpaqueType*;
///
*
* Obtain the (possibly scalable) number of elements in a vector type.
*
* This only works on types that represent vectors (fixed or scalable).
*
* @see llvm::VectorType::getNumElements()

///

cdecl LLVMGetVectorSize(LLVMOpaqueType* VectorTy) -> uint;
///
*
* Get the pointer value for the associated ConstantPtrAuth constant.
*
* @see llvm::ConstantPtrAuth::getPointer

///

cdecl LLVMGetConstantPtrAuthPointer(LLVMOpaqueValue* PtrAuth) -> LLVMOpaqueValue*;
///
*
* Get the key value for the associated ConstantPtrAuth constant.
*
* @see llvm::ConstantPtrAuth::getKey

///

cdecl LLVMGetConstantPtrAuthKey(LLVMOpaqueValue* PtrAuth) -> LLVMOpaqueValue*;
///
*
* Get the discriminator value for the associated ConstantPtrAuth constant.
*
* @see llvm::ConstantPtrAuth::getDiscriminator

///

cdecl LLVMGetConstantPtrAuthDiscriminator(LLVMOpaqueValue* PtrAuth) -> LLVMOpaqueValue*;
///
*
* Get the address discriminator value for the associated ConstantPtrAuth
* constant.
*
* @see llvm::ConstantPtrAuth::getAddrDiscriminator

///

cdecl LLVMGetConstantPtrAuthAddrDiscriminator(LLVMOpaqueValue* PtrAuth) -> LLVMOpaqueValue*;
///
*
* @}

///

///
*
* @defgroup LLVMCCoreTypeOther Other Types
*
* @{

///

///
*
* Create a void type in a context.

///

cdecl LLVMVoidTypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
///
*
* Create a label type in a context.

///

cdecl LLVMLabelTypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
///
*
* Create a X86 AMX type in a context.

///

cdecl LLVMX86AMXTypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
///
*
* Create a token type in a context.

///

cdecl LLVMTokenTypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
///
*
* Create a metadata type in a context.

///

cdecl LLVMMetadataTypeInContext(LLVMOpaqueContext* C) -> LLVMOpaqueType*;
///
*
* These are similar to the above functions except they operate on the
* global context.

///

cdecl LLVMVoidType() -> LLVMOpaqueType*;
cdecl LLVMLabelType() -> LLVMOpaqueType*;
cdecl LLVMX86AMXType() -> LLVMOpaqueType*;
///
*
* Create a target extension type in LLVM context.

///

cdecl LLVMTargetExtTypeInContext(LLVMOpaqueContext* C, byte* Name, LLVMOpaqueType** TypeParams, uint TypeParamCount, uint* IntParams, uint IntParamCount) -> LLVMOpaqueType*;
///
*
* Obtain the name for this target extension type.
*
* @see llvm::TargetExtType::getName()

///

cdecl LLVMGetTargetExtTypeName(LLVMOpaqueType* TargetExtTy) -> byte*;
///
*
* Obtain the number of type parameters for this target extension type.
*
* @see llvm::TargetExtType::getNumTypeParameters()

///

cdecl LLVMGetTargetExtTypeNumTypeParams(LLVMOpaqueType* TargetExtTy) -> uint;
///
*
* Get the type parameter at the given index for the target extension type.
*
* @see llvm::TargetExtType::getTypeParameter()

///

cdecl LLVMGetTargetExtTypeTypeParam(LLVMOpaqueType* TargetExtTy, uint Idx) -> LLVMOpaqueType*;
///
*
* Obtain the number of int parameters for this target extension type.
*
* @see llvm::TargetExtType::getNumIntParameters()

///

cdecl LLVMGetTargetExtTypeNumIntParams(LLVMOpaqueType* TargetExtTy) -> uint;
///
*
* Get the int parameter at the given index for the target extension type.
*
* @see llvm::TargetExtType::getIntParameter()

///

cdecl LLVMGetTargetExtTypeIntParam(LLVMOpaqueType* TargetExtTy, uint Idx) -> uint;
///
*
* @}

///

///
*
* @}

///

///
*
* @defgroup LLVMCCoreValues Values
*
* The bulk of LLVM's object model consists of values, which comprise a very
* rich type hierarchy.
*
* LLVMValueRef essentially represents llvm::Value. There is a rich
* hierarchy of classes within this type. Depending on the instance
* obtained, not all APIs are available.
*
* Callers can determine the type of an LLVMValueRef by calling the
* LLVMIsA* family of functions (e.g. LLVMIsAArgument()). These
* functions are defined by a macro, so it isn't obvious which are
* available by looking at the Doxygen source code. Instead, look at the
* source definition of LLVM_FOR_EACH_VALUE_SUBCLASS and note the list
* of value names given. These value names also correspond to classes in
* the llvm::Value hierarchy.
*
* @{

///

// Currently, clang-format tries to format the LLVM_FOR_EACH_VALUE_SUBCLASS

// macro in a progressively-indented fashion, which is not desired

// clang-format off

#psub LLVM_FOR_EACH_VALUE_SUBCLASS(macro) macro(Argument)                           macro(BasicBlock)                         macro(InlineAsm)                          macro(User)                               macro(Constant)                         macro(BlockAddress)                   macro(ConstantAggregateZero)          macro(ConstantArray)                  macro(ConstantDataSequential)         macro(ConstantDataArray)            macro(ConstantDataVector)           macro(ConstantExpr)                   macro(ConstantFP)                     macro(ConstantInt)                    macro(ConstantByte)                   macro(ConstantPointerNull)            macro(ConstantStruct)                 macro(ConstantTokenNone)              macro(ConstantVector)                 macro(ConstantPtrAuth)                macro(GlobalValue)                    macro(GlobalAlias)                  macro(GlobalObject)                 macro(Function)                   macro(GlobalVariable)             macro(GlobalIFunc)                macro(UndefValue)                     macro(PoisonValue)                    macro(Instruction)                      macro(UnaryOperator)                  macro(BinaryOperator)                 macro(CallInst)                       macro(IntrinsicInst)                macro(DbgInfoIntrinsic)           macro(DbgVariableIntrinsic)     macro(DbgDeclareInst)         macro(DbgLabelInst)             macro(MemIntrinsic)               macro(MemCpyInst)               macro(MemMoveInst)              macro(MemSetInst)               macro(CmpInst)                        macro(FCmpInst)                     macro(ICmpInst)                     macro(ExtractElementInst)             macro(GetElementPtrInst)              macro(InsertElementInst)              macro(InsertValueInst)                macro(LandingPadInst)                 macro(PHINode)                        macro(SelectInst)                     macro(ShuffleVectorInst)              macro(StoreInst)                      macro(UncondBrInst)                   macro(CondBrInst)                     macro(IndirectBrInst)                 macro(InvokeInst)                     macro(ReturnInst)                     macro(SwitchInst)                     macro(UnreachableInst)                macro(ResumeInst)                     macro(CleanupReturnInst)              macro(CatchReturnInst)                macro(CatchSwitchInst)                macro(CallBrInst)                     macro(FuncletPadInst)                 macro(CatchPadInst)                 macro(CleanupPadInst)               macro(UnaryInstruction)               macro(AllocaInst)                   macro(CastInst)                     macro(AddrSpaceCastInst)          macro(BitCastInst)                macro(FPExtInst)                  macro(FPToSIInst)                 macro(FPToUIInst)                 macro(FPTruncInst)                macro(IntToPtrInst)               macro(PtrToIntInst)               macro(SExtInst)                   macro(SIToFPInst)                 macro(TruncInst)                  macro(UIToFPInst)                 macro(ZExtInst)                   macro(ExtractValueInst)             macro(LoadInst)                     macro(VAArgInst)                    macro(FreezeInst)                   macro(AtomicCmpXchgInst)              macro(AtomicRMWInst)                  macro(FenceInst);

// clang-format on

///
*
* @defgroup LLVMCCoreValueGeneral General APIs
*
* Functions in this section work on all LLVMValueRef instances,
* regardless of their sub-type. They correspond to functions available
* on llvm::Value.
*
* @{

///

///
*
* Obtain the type of a value.
*
* @see llvm::Value::getType()

///

cdecl LLVMTypeOf(LLVMOpaqueValue* Val) -> LLVMOpaqueType*;
///
*
* Obtain the enumerated type of a Value instance.
*
* @see llvm::Value::getValueID()

///

cdecl LLVMGetValueKind(LLVMOpaqueValue* Val) -> LLVMValueKind;
///
*
* Obtain the string name of a value.
*
* @see llvm::Value::getName()

///

cdecl LLVMGetValueName2(LLVMOpaqueValue* Val, ulong* Length) -> byte*;
///
*
* Set the string name of a value.
*
* @see llvm::Value::setName()

///

cdecl LLVMSetValueName2(LLVMOpaqueValue* Val, byte* Name, ulong NameLen) -> void;
///
*
* Dump a representation of a value to stderr.
*
* @see llvm::Value::dump()

///

cdecl LLVMDumpValue(LLVMOpaqueValue* Val) -> void;
///
*
* Return a string representation of the value. Use
* LLVMDisposeMessage to free the string.
*
* @see llvm::Value::print()

///

cdecl LLVMPrintValueToString(LLVMOpaqueValue* Val) -> byte*;
///
*
* Obtain the context to which this value is associated.
*
* @see llvm::Value::getContext()

///

cdecl LLVMGetValueContext(LLVMOpaqueValue* Val) -> LLVMOpaqueContext*;
///
*
* Return a string representation of the DbgRecord. Use
* LLVMDisposeMessage to free the string.
*
* @see llvm::DbgRecord::print()

///

cdecl LLVMPrintDbgRecordToString(LLVMOpaqueDbgRecord* Record) -> byte*;
///
*
* Replace all uses of a value with another one.
*
* @see llvm::Value::replaceAllUsesWith()

///

cdecl LLVMReplaceAllUsesWith(LLVMOpaqueValue* OldVal, LLVMOpaqueValue* NewVal) -> void;
///
*
* Determine whether the specified value instance is constant.

///

cdecl LLVMIsConstant(LLVMOpaqueValue* Val) -> int;
///
*
* Determine whether a value instance is undefined.

///

cdecl LLVMIsUndef(LLVMOpaqueValue* Val) -> int;
///
*
* Determine whether a value instance is poisonous.

///

cdecl LLVMIsPoison(LLVMOpaqueValue* Val) -> int;
///
*
* Convert value instances between types.
*
* Internally, an LLVMValueRef is "pinned" to a specific type. This
* series of functions allows you to cast an instance to a specific
* type.
*
* If the cast is not valid for the specified type, NULL is returned.
*
* @see llvm::dyn_cast_or_null<>

///

#psub LLVM_DECLARE_VALUE_CAST(name) LLVM_C_ABI LLVMValueRef LLVMIsA{name}(LLVMValueRef Val);;

// LLVM_FOR_EACH_VALUE_SUBCLASS(LLVM_DECLARE_VALUE_CAST)  // could not expand -- manual translation needed
cdecl LLVMIsAArgument(LLVMOpaqueValue* Val) -> LLVMOpaqueValue*;
cdecl LLVMIsABasicBlock(LLVMOpaqueValue* Val) -> LLVMOpaqueValue*;
cdecl LLVMIsAInlineAsm(LLVMOpaqueValue* Val) -> LLVMOpaqueValue*;
cdecl LLVMIsAUser(LLVMOpaqueValue* Val) -> LLVMOpaqueValue*;
cdecl LLVMIsAConstant(LLVMOpaqueValue* Val) -> LLVMOpaqueValue*;
cdecl LLVMIsABlockAddress(LLVMOpaqueValue* Val) -> LLVMOpaqueValue*;
cdecl LLVMIsAConstantAggregateZero(LLVMOpaqueValue* Val) -> LLVMOpaqueValue*;
cdecl LLVMIsAConstantArray(LLVMOpaqueValue* Val) -> LLVMOpaqueValue*;
cdecl LLVMIsAConstantDataSequential(LLVMOpaqueValue* Val) -> LLVMOpaqueValue*;
cdecl LLVMIsAConstantDataArray(LLVMOpaqueValue* Val) -> LLVMOpaqueValue*;
cdecl LLVMIsAConstantDataVector(LLVMOpaqueValue* Val) -> LLVMOpaqueValue*;
cdecl LLVMIsAConstantExpr(LLVMOpaqueValue* Val) -> LLVMOpaqueValue*;
cdecl LLVMIsAConstantFP(LLVMOpaqueValue* Val) -> LLVMOpaqueValue*;
cdecl LLVMIsAConstantInt(LLVMOpaqueValue* Val) -> LLVMOpaqueValue*;
cdecl LLVMIsAConstantByte(LLVMOpaqueValue* Val) -> LLVMOpaqueValue*;
